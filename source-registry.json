{
  "version": "final-working-2026-06-08",
  "policy": "Official or host-public sources only. Generic source-watch pages are not publishable events.",
  "officialDomains": [
    "vatican.va",
    "press.vatican.va",
    "iaea.org",
    "royal.uk",
    "whitehouse.gov",
    "state.gov",
    "gov.uk",
    "consilium.europa.eu",
    "commission.europa.eu",
    "nato.int",
    "un.org",
    "who.int",
    "worldbank.org",
    "imf.org",
    "elysee.fr"
  ],
  "adapters": [
    {
      "name": "vatican-travel",
      "domains": ["vatican.va", "press.vatican.va"],
      "accept": ["/travels/", "Apostolic Journey", "itinerary"],
      "reject": ["homepage", "generic profile", "media index"],
      "requires": ["person", "date", "city", "official source"]
    },
    {
      "name": "iaea-statements",
      "domains": ["iaea.org"],
      "accept": ["/newscenter/statements/", "/newscenter/pressreleases/", "Rafael Grossi"],
      "reject": ["topic page", "profile page", "watch card"],
      "requires": ["person", "date", "city", "official source"]
    },
    {
      "name": "royal-engagements",
      "domains": ["royal.uk"],
      "accept": ["/news-and-activity/", "future engagements", "Court Circular"],
      "reject": ["generic royal diary watch", "homepage"],
      "requires": ["named royal", "date", "place", "official source"]
    }
  ]
}
