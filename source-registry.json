{
  "version": "2026-06-08-source-registry",
  "policy": "Use official or host-public sources only for publishable events. Reject generic watch/index/profile/FAQ/programme pages unless they contain a person, date, city, specific public event and official source.",
  "officialDomains": [
    "vatican.va",
    "press.vatican.va",
    "iaea.org",
    "royal.uk",
    "whitehouse.gov",
    "state.gov",
    "gov.uk",
    "consilium.europa.eu",
    "commission.europa.eu",
    "nato.int",
    "un.org",
    "who.int",
    "worldbank.org",
    "imf.org",
    "elysee.fr"
  ],
  "sourceAdapters": [
    {
      "id": "vatican_travels",
      "domain": "vatican.va",
      "acceptUrlContains": ["/travels/"],
      "rejectTitleContains": ["home", "profile", "biography", "faq", "programme watch"],
      "requires": ["person", "date", "city", "official_source"]
    },
    {
      "id": "iaea_statements",
      "domain": "iaea.org",
      "acceptUrlContains": ["/newscenter/statements/", "/newscenter/pressreleases/"],
      "rejectTitleContains": ["topic", "profile", "watch", "homepage"],
      "requires": ["Rafael Grossi", "date", "city_or_headquarters", "official_source"]
    },
    {
      "id": "royal_engagements",
      "domain": "royal.uk",
      "acceptUrlContains": ["/news-and-activity/", "/media-centre/future-engagements"],
      "rejectTitleContains": ["watch", "homepage", "generic diary"],
      "requires": ["named_royal", "date", "place", "official_source"]
    }
  ],
  "blockedEventTitlePatterns": [
    "IAEA nuclear diplomacy watch",
    "City of London finance diplomacy watch",
    "Think-tank leadership events watch",
    "Royal diaries and state-visit watch",
    "source-watch",
    "homepage",
    "FAQ",
    "fact sheet",
    "profile",
    "programme"
  ]
}
