{
  "policy": "official-source-only; no generic watch cards as dated events",
  "officialDomains": [
    "vatican.va",
    "press.vatican.va",
    "iaea.org",
    "royal.uk",
    "whitehouse.gov",
    "state.gov",
    "gov.uk",
    "elysee.fr",
    "bundesregierung.de",
    "consilium.europa.eu",
    "commission.europa.eu",
    "nato.int",
    "un.org",
    "who.int",
    "worldbank.org",
    "imf.org"
  ],
  "crawlerRules": {
    "rejectTitlesMatching": [
      "watch",
      "source-watch",
      "faq",
      "fact sheet",
      "programme",
      "homepage",
      "profile page",
      "privacy",
      "terms",
      "sitemap"
    ],
    "requireForEvents": [
      "personId",
      "startsAt",
      "title",
      "location.city",
      "sourcePack[0].url",
      "sourcePack[0].type=official"
    ]
  },
  "sourceAdapters": {
    "vatican": {
      "domains": ["vatican.va", "press.vatican.va"],
      "accepted": ["travel itinerary pages", "public audience pages", "official journey documents"],
      "rejected": ["generic news index", "profile pages"]
    },
    "iaea": {
      "domains": ["iaea.org"],
      "accepted": ["official statements", "official visit reports", "Board of Governors pages"],
      "rejected": ["topic landing pages", "generic nuclear diplomacy watch"]
    },
    "royal": {
      "domains": ["royal.uk"],
      "accepted": ["future engagements", "official news activity", "Court Circular entries"],
      "rejected": ["generic diary index without person/date/place"]
    }
  }
}
