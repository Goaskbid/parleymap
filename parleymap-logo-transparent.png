{
  "alertTypes": [
    {
      "kind": "New attendee announced",
      "example": "A public participant list names a new minister, CEO or central banker.",
      "action": "Create Person ↔ Event edge and show an alert."
    },
    {
      "kind": "Agenda published",
      "example": "A summit posts its first programme or PDF agenda.",
      "action": "Extract sessions, themes and likely attendee clusters."
    },
    {
      "kind": "Speaker added",
      "example": "A conference adds a keynote or panel participant.",
      "action": "Update the profile timeline and notify subscribed users."
    },
    {
      "kind": "Event moved",
      "example": "Host changes city, dates or venue.",
      "action": "Retire old watch card and publish the updated public window."
    },
    {
      "kind": "Registration opens",
      "example": "A major forum opens registration or media accreditation.",
      "action": "Flag the event for closer agenda monitoring."
    },
    {
      "kind": "Call readout posted",
      "example": "An official page publishes a telephone conversation.",
      "action": "Add a red call edge with source and counterpart profile."
    }
