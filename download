  async function hydrateVisiblePortraits(list) {
    const missing = (list || []).filter((r) => !r.imageUrl && r.wikiTitle && !hydratedPortraitIds.has(r.id));
    if (!missing.length) return;
    missing.forEach((r) => hydratedPortraitIds.add(r.id));
    const batches = [];
    for (let i = 0; i < missing.length; i += 40) batches.push(missing.slice(i, i + 40));
    for (const batch of batches) {
      try {
        const params = new URLSearchParams({
          action: "query",
          origin: "*",
          format: "json",
          redirects: "1",
          prop: "pageimages",
          piprop: "thumbnail",
          pithumbsize: "220",
          titles: batch.map((r) => r.wikiTitle).join("|")
        });
        const res = await fetch(`https://en.wikipedia.org/w/api.php?${params.toString()}`);
        if (!res.ok) continue;
        const json = await res.json();
        const byTitle = new Map();
        batch.forEach((r) => {
          byTitle.set(key(r.wikiTitle), r);
          byTitle.set(key(String(r.wikiTitle || "").replaceAll("_", " ")), r);
          byTitle.set(key(r.name), r);
          byTitle.set(key(r.canonicalName), r);
        });
        (json.query?.normalized || []).forEach((n) => {
          const r = byTitle.get(key(n.from));
          if (r) byTitle.set(key(n.to), r);
        });
        (json.query?.redirects || []).forEach((n) => {
          const r = byTitle.get(key(n.from));
          if (r) byTitle.set(key(n.to), r);
        });
        Object.values(json.query?.pages || {}).forEach((page) => {
          const url = cleanPortraitUrl(page?.thumbnail?.source || "");
          const r = byTitle.get(key(page?.title));
          if (!url || !r || badPortraitUrl(url, r.name)) return;
          r.imageUrl = url;
          portraitByTitle.set(key(page.title), url);
          portraitByTitle.set(key(r.wikiTitle), url);
          portraitByTitle.set(key(r.name), url);
          portraitByTitle.set(key(r.canonicalName), url);
          const p = mappedPersonForRoster(r);
          if (p && !p.imageUrl) p.imageUrl = url;
        });
      } catch (_) {}
    }
    renderTop20List();
    renderRankings();
    if (els.quickSearch?.value) renderQuickResults(els.quickSearch.value);
    if (!selectedPerson) renderStartMarkers(); else renderTimelineMap({ keepView: true });
    if (selectedPerson || selectedRoster) renderProfile(selectedPerson, selectedRoster);
    schedulePortraitHydration();
  }

  function seedPortraitMap() {
    [...roster, ...people].forEach((item) => {
      const title = portraitTitle(item, item);
      const url = cleanPortraitUrl(item?.imageUrl || "");
      if (title && url) portraitByTitle.set(key(title), url);
      if (item?.name && url) portraitByTitle.set(key(item.name), url);
      if (item?.canonicalName && url) portraitByTitle.set(key(item.canonicalName), url);
    });
  }

  function portraitTitle(subject, r) {
    const title = subject?.wikiTitle || r?.wikiTitle || subject?.wikipediaTitle || r?.wikipediaTitle || subject?.canonicalName || subject?.name || r?.name || "";
    return String(title || "").replace(/\s+/g, "_");
  }

  function cleanPortraitUrl(url) {
    const s = String(url || "").trim();
    if (!s || /^(javascript|data:text\/html)/i.test(s)) return "";
    return s;
  }
  function badPortraitUrl(url, name = "") {
    const s = decodeURIComponent(String(url || "")).toLowerCase();
    if (!s) return false;
    if (/\.svg(\?|$)/i.test(s)) return true;
    if (/flag_of|coat_of_arms|seal_of|logo|emblem|icon|map_|painting|statue|drawing|caricature|signature|arms_of/i.test(s)) return true;
    const n = key(name);
    if (n && /(generic|placeholder|silhouette|no_image)/i.test(s)) return true;
    return false;
  }

  function schedulePortraitHydration() {
    clearTimeout(portraitHydrationTimer);
    portraitHydrationTimer = setTimeout(refreshPortraitNodes, 80);
  }

  async function refreshPortraitNodes() {
    const nodes = qsAll(".avatar-photo[data-wiki-title]").filter((node) => node.dataset.portraitOk !== "0" && !node.querySelector("img"));
    if (!nodes.length) return;
    const missing = [];
    for (const node of nodes) {
      const title = node.dataset.wikiTitle || node.dataset.personName || "";
      const known = portraitByTitle.get(key(title)) || portraitByTitle.get(key(String(title).replaceAll("_", " "))) || portraitByTitle.get(key(node.dataset.personName));
      if (known) {
        setPortraitNode(node, known);
      } else if (title && !portraitTitleRequests.has(key(title))) {
        portraitTitleRequests.add(key(title));
        missing.push({ title, nodeName: node.dataset.personName || title });
      }
    }
    if (!missing.length) return;
    for (let i = 0; i < missing.length; i += 40) {
      const batch = missing.slice(i, i + 40);
      try {
        const params = new URLSearchParams({
          action: "query",
          origin: "*",
          format: "json",
          redirects: "1",
          prop: "pageimages",
          piprop: "thumbnail",
          pithumbsize: "220",
          titles: batch.map((x) => x.title).join("|")
        });
        const res = await fetch(`https://en.wikipedia.org/w/api.php?${params.toString()}`);
        if (!res.ok) continue;
        const json = await res.json();
        const byTitle = new Map();
        batch.forEach((x) => {
          byTitle.set(key(x.title), x);
          byTitle.set(key(String(x.title).replaceAll("_", " ")), x);
          byTitle.set(key(x.nodeName), x);
        });
        (json.query?.normalized || []).forEach((n) => { const x = byTitle.get(key(n.from)); if (x) byTitle.set(key(n.to), x); });
        (json.query?.redirects || []).forEach((n) => { const x = byTitle.get(key(n.from)); if (x) byTitle.set(key(n.to), x); });
        Object.values(json.query?.pages || {}).forEach((page) => {
          const url = cleanPortraitUrl(page?.thumbnail?.source || "");
          const match = byTitle.get(key(page?.title));
          if (!url || !match) return;
          portraitByTitle.set(key(page.title), url);
          portraitByTitle.set(key(match.title), url);
          portraitByTitle.set(key(match.nodeName), url);
          const r = roster.find((x) => key(x.wikiTitle) === key(match.title) || key(x.name) === key(match.nodeName) || key(x.name) === key(page.title));
          if (r && !r.imageUrl) r.imageUrl = url;
          const p = people.find((x) => key(x.canonicalName) === key(match.nodeName) || key(x.wikiTitle) === key(match.title) || key(x.canonicalName) === key(page.title));
          if (p && !p.imageUrl) p.imageUrl = url;
          qsAll(".avatar-photo[data-wiki-title]").forEach((node) => {
            if (key(node.dataset.wikiTitle) === key(match.title) || key(node.dataset.personName) === key(match.nodeName) || key(node.dataset.personName) === key(page.title)) setPortraitNode(node, url);
          });
        });
      } catch (_) {}
    }
  }

  function setPortraitNode(node, url) {
    if (!node || !url || node.querySelector("img")) return;
    const img = document.createElement("img");
    img.src = url;
    img.alt = node.dataset.personName || "portrait";
    img.loading = "eager";
    img.decoding = "async";
    img.referrerPolicy = "no-referrer";
    img.onload = () => node.classList.add("has-photo");
    img.onerror = () => img.remove();
    node.appendChild(img);
  }

  function delegatedHover(e) {
    const el = e.target.closest('[data-hover-title]');
    if (!el) return;
    showHoverAt(e, { title: el.dataset.hoverTitle, detail: el.dataset.hoverDetail, body: el.dataset.hoverBody, html: el.dataset.hoverHtml });
