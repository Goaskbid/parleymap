  function networkPersonRows(records) {
    const byPerson = new Map();
    for (const rec of records) {
      const p = peopleById.get(rec.personId);
      if (!p || !rec.location) continue;
      const row = byPerson.get(p.id) || { person: p, records: [], citiesSet: new Set(), latest: rec };
      row.records.push(rec);
      row.citiesSet.add(rec.location.city || rec.location.countryName || "public venue");
      if (new Date(rec.startsAt) > new Date(row.latest.startsAt)) row.latest = rec;
      byPerson.set(p.id, row);
    }
    return [...byPerson.values()].map((row) => ({
      ...row,
      cities: [...row.citiesSet],
      score: row.records.length * 4 + row.citiesSet.size * 2 + dateScore(row.latest.startsAt) / 1e13
    })).sort((a, b) => b.score - a.score);
  }

  function networkCityRows(records) {
    const byCity = new Map();
    for (const rec of records) {
      if (!rec.location) continue;
      const k = `${key(rec.location.city)}|${rec.location.countryCode || ""}`;
      const row = byCity.get(k) || { city: rec.location.city || rec.location.countryName || "public venue", countryCode: rec.location.countryCode, countryName: rec.location.countryName, lat: rec.location.lat, lng: rec.location.lng, count: 0, people: new Set(), latest: rec };
      row.count += 1;
      row.people.add(rec.personId);
      if (new Date(rec.startsAt) > new Date(row.latest.startsAt)) row.latest = rec;
      byCity.set(k, row);
    }
    return [...byCity.values()].sort((a, b) => b.count - a.count || b.people.size - a.people.size || a.city.localeCompare(b.city));
