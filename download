  function normalizeTopicName(name) {
    const raw = oneLine(name || "", 48).trim();
    if (!raw) return "";
    const k = key(raw);
    const map = [
      [/\b(ai|artificial intelligence|openai|machine learning|digital transformation|cloud|cloud infrastructure)\b/i, "AI"],
      [/\b(defence|defense|military|security|nato|munich security|shangri\-la|weapons|deterrence)\b/i, "Defence"],
      [/\b(inflation|rates|monetary|central bank|fed|ecb|fomc|jackson hole|liquidity)\b/i, "Inflation"],
      [/\b(energy|oil|gas|opec|ceraweek|adipec|lng|power grid|commodities)\b/i, "Energy"],
      [/\b(china|beijing|xi|apec|boao|indo\-pacific)\b/i, "China"],
      [/\b(semiconductor|semiconductors|chips|nvidia|tsmc|computex|supply chain)\b/i, "Semiconductors"],
      [/\b(climate|cop\d*|carbon|transition|green finance|unfccc)\b/i, "Climate"],
      [/\b(trade|wto|tariff|supply chain|industrial policy|apec)\b/i, "Trade"],
      [/\b(ukraine|zelensky|peace talks|ceasefire|war diplomacy)\b/i, "Ukraine"],
      [/\b(riyadh|abu dhabi|doha|israel|iran|saudi|gulf|middle east|opec)\b/i, "Middle East"],
      [/\b(debt|imf|world bank|development finance|emerging markets|financing)\b/i, "Debt"],
      [/\b(who|health|gavi|pandemic|vaccine|public health)\b/i, "Health"],
      [/\b(cyber|cybersecurity|security technology|disinformation)\b/i, "Cyber"],
      [/\b(space|satellite|spacex|defence space)\b/i, "Space"],
      [/\b(crypto|digital assets|stablecoin|payments|cbdc)\b/i, "Payments"],
      [/\b(food|agriculture|grain|fertilizer)\b/i, "Food security"],
      [/\b(geopolitics|geopolitical|global governance|multilateralism)\b/i, "Diplomacy"]
    ];
    for (const [rx, value] of map) if (rx.test(raw)) return value;
    if (/^(us|u\.s\.|usa|united states|policy|public|meeting|summit|event|appearance|government|minister|president|prime minister|foreign ministry|foreign minister|foreign ministers)$/i.test(raw)) return "";
    if (raw.length < 3 || raw.length > 28) return "";
    if (/\d/.test(raw) && !/cop\d/i.test(raw)) return "";
    const words = raw.split(/\s+/);
    if (words.length > 3) return "";
    return titleCase(raw);
  }

  function isUsefulTopicName(name) {
    const n = key(name);
    if (!n || n.length < 2) return false;
    const reject = new Set(["diplomacy", "foreign minister", "foreign ministers", "un", "eu", "united states", "policy", "government", "public", "event", "events", "meeting", "meetings", "summit", "summits", "conference", "forum", "forums", "source", "official", "visit", "visits", "travel", "agenda", "watch", "leader", "leaders", "frequent traveller", "frequent traveler"]);
    if (reject.has(n)) return false;
    if (/^(g7|g20|brics|apec|nato|opec|bis|imf|wef|fii|wto|oecd)$/.test(n)) return false;
    if (/^\d{4}$/.test(n)) return false;
    return true;
  }

  function titleCase(value) {
    return String(value || "").replace(/\w\S*/g, (word) => word.length <= 3 && word === word.toUpperCase() ? word : word.charAt(0).toUpperCase() + word.slice(1).toLowerCase());
  }

