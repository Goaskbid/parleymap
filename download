    if (els.timelineStops) els.timelineStops.innerHTML = "";
    if (els.scrubber) { els.scrubber.max = 0; els.scrubber.value = 0; }

    if (!fallbackMode && map) {
      drawHeat(loc, Math.max(1.25, Math.min(2.6, .9 + peopleList.length / 5)), countryColor(loc.countryCode || "UN"));
      const items = deOverlapAnchors(peopleList.map((entry) => ({ roster: entry.roster, person: entry.person, trueAnchor: loc, anchor: loc })));
      drawDisplayLeaderLines(items);
      items.forEach((item) => {
        const marker = L.marker([item.anchor.lat, item.anchor.lng], { icon: personDivIcon(item.roster || item.person, item.person, { label: shortName(item.roster?.name || item.person?.canonicalName || "Profile") }), riseOnHover: true, keyboard: true });
        marker.on("click", () => item.roster?.id && selectRoster(item.roster.id));
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.roster?.name || item.person?.canonicalName || "Tracked profile", detail: `${compactDate(agenda.startsAt)} · ${loc.city}`, body: `${title}. Click to open this person’s profile and public trail.` }));
        marker.on("mousemove", (e) => moveHover(e.originalEvent));
        marker.on("mouseout", hideHover);
        marker.addTo(layers.markers);
      });
      const eventMarker = L.marker([loc.lat, loc.lng], { icon: L.divIcon({ className: "pm-div-icon", html: `<div class="agenda-anchor-marker">${flagHtml(loc.countryCode, loc.countryName)}<b>${esc(compactDate(agenda.startsAt))}</b></div>`, iconSize: [96, 42], iconAnchor: [48, 21] }), riseOnHover: true, keyboard: true });
      eventMarker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title, detail: `${flagEmoji(loc.countryCode)} ${loc.city}`, body: agenda.whyItMatters || agenda.summary || "Public agenda card." }));
      eventMarker.on("mousemove", (e) => moveHover(e.originalEvent));
      eventMarker.on("mouseout", hideHover);
      eventMarker.addTo(layers.markers);
      const bounds = [[loc.lat, loc.lng], ...items.map((x) => [x.anchor.lat, x.anchor.lng])];
      if (bounds.length > 1) map.fitBounds(bounds, { padding: [80, 80], maxZoom: peopleList.length > 7 ? 5 : 6, animate: true });
      else if (loc.lat && loc.lng) map.flyTo([loc.lat, loc.lng], 5, { duration: 1.1 });
    }

    const topics = topicsForRecord(agenda).slice(0, 7).map((x) => `<span class="topic-pill"><span class="topic-icon">${topicIcon(x)}</span>${esc(x)}</span>`).join("");
    const sourcePills = sourcePillsForLinks(agenda.sourcePack || [], title);
    const faceRows = peopleList.length ? peopleList.slice(0, 18).map((entry) => `<button type="button" data-roster-id="${esc(entry.roster.id)}">${miniFace(entry.person || mappedPersonForRoster(entry.roster))}<span>${esc(entry.roster.name)}</span></button>`).join("") : `<span class="empty-note">Named participants appear after a source names them.</span>`;
    const outcome = agendaOutcomeComment(agenda, peopleList.length);
    els.profile.innerHTML = `<div class="summit-profile"><h3>${esc(title)}</h3><p>${flagHtml(loc.countryCode, loc.countryName)} ${esc([loc.city, loc.countryName].filter(Boolean).join(", "))} · ${esc(compactDate(agenda.startsAt))}</p><div class="topic-pills">${topics}</div><div class="summit-attendees">${faceRows}</div><div class="bio-lines"><div><span class="line-label">Signal</span> ${esc(outcome.signal)}</div><div><span class="line-label">What moved</span> ${esc(outcome.moved)}</div><div><span class="line-label">Next watch</span> ${esc(outcome.next)}</div><div><span class="line-label">Sources</span> ${sourcePills || "A source pill appears when the agenda or attendance page is available."}</div></div></div>`;
    qsAll("[data-roster-id]", els.profile).forEach((b) => b.addEventListener("click", () => b.dataset.rosterId && selectRoster(b.dataset.rosterId)));
    schedulePortraitHydration();
  }



  function agendaOutcomeComment(agenda, count) {
    const hay = key([agenda.title, agenda.type, agenda.whyItMatters, ...(agenda.topics || [])].join(" "));
    const base = agenda.whyItMatters || agenda.summary || "The agenda places influential people in the same public room.";
    let moved = "The signal is repetition: who appears together, who comes back, and which language survives into the next forum.";
    let next = "Watch for named speakers, bilateral readouts, follow-up communiqués and repeated language in the next agenda.";
    if (/g7|g20|brics|apec/.test(hay)) { moved = "Leader and minister language tends to move from sherpa work into trade, sanctions, security and finance wording."; next = "Watch the communique, side meetings and ministerial hand-offs."; }
    if (/nato|munich|shangri|defence|defense/.test(hay)) { moved = "Security forums reveal burden-sharing, procurement priorities and which regional risks are becoming central."; next = "Watch defence-minister follow-ups, spending language and industry-side attendance."; }
    if (/jackson|sintra|fomc|central bank|inflation|bis/.test(hay)) { moved = "Markets watch tone changes, not just headlines: rates, liquidity, banking stress and inflation confidence."; next = "Watch speech text, panel transcripts and subsequent central-bank minutes."; }
    if (/ai|semiconductor|technology|sun valley|ces/.test(hay)) { moved = "Technology rooms show which policy concerns are crossing into capital allocation and regulation."; next = "Watch speaker additions, government attendance and whether safety language becomes procurement language."; }
    if (/energy|opec|ceraweek|adipec/.test(hay)) { moved = "Energy events connect supply, security and capital spending; repeated attendees matter more than a single speech."; next = "Watch production language, financing pledges and minister/CEO side meetings."; }
    return { signal: `${oneLine(base, 150)} ${count ? `${count} tracked profile${count === 1 ? "" : "s"} are linked in this build.` : "Named attendees are still being watched."}`, moved, next };
  }

  function focusSummit(keyValue) {
