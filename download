  function orgPenetrationRowsV48() {
    const families = eventFamilies().slice(0, 18);
    return organizationFamilies().map((org) => {
      const records = appearances.filter((a)=>org.rx.test(recordHay(a)) || org.rx.test(peopleById.get(a.personId)?.organization || '') || org.rx.test(peopleById.get(a.personId)?.roleTitle || ''));
      const agendas = uniqueAgendas(eventAgendas).filter((a)=>org.rx.test(agendaHay(a)));
      const eventCounts = families.map((fam)=>({fam, records:records.filter((a)=>fam.rx.test(recordHay(a))).length, agendas:agendas.filter((a)=>fam.rx.test(agendaHay(a))).length}));
      const confirmed = eventCounts.filter((x)=>x.records || x.agendas).length;
      const reps = [...new Set(records.map((a)=>a.personId))].map((id)=>peopleById.get(id)).filter(Boolean).slice(0,5);
      if (!reps.length) records.slice(0,8).map((a)=>peopleById.get(a.personId)).filter(Boolean).forEach((p)=>reps.push(p));
      return { org, records, agendas, eventCounts, confirmed, reps, score: confirmed*5 + records.length + agendas.length*2 };
    }).filter((r)=>r.score>0).sort((a,b)=>b.score-a.score).slice(0,12);
  }

