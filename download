  function startList() {
    let list = hasActiveSearchOrFilter() ? roster.slice() : openingPresetRoster();
    const q = key(state.query);
    if (q) list = roster.filter((r) => rosterSearchText(r).includes(q));
    if (state.category !== "ALL") list = list.filter((r) => normalizeCategory(r) === state.category);
    if (state.country !== "ALL") list = list.filter((r) => r.countryFocus === state.country || latestAnchorForRoster(r).countryCode === state.country);
    if (state.sector !== "ALL") list = list.filter((r) => r.sector === state.sector);
    const limit = hasActiveSearchOrFilter() ? 24 : openingPresetLimit();
    return list.slice(0, limit);
  }

  function openingPresetRoster() {
    const preset = state.openingPreset || "TOP10";
    if (preset === "TOP20") return roster.slice(0, 20);
    if (preset === "ALL") return roster.slice(0, 200);
    if (preset === "EUROPE") return roster.filter((r) => /europe/i.test(r.region || "") || ["EU", "GB", "FR", "DE", "IT", "ES", "NL", "BE", "CH", "SE", "NO", "DK", "FI", "PL", "UA", "TR", "RU", "VA"].includes(String(r.countryFocus || "").toUpperCase())).slice(0, 10);
    if (preset === "NORTH_AMERICA") return roster.filter((r) => /north america/i.test(r.region || "") || ["US", "CA", "MX"].includes(String(r.countryFocus || "").toUpperCase())).slice(0, 10);
    if (preset === "ASIA") return roster.filter((r) => /asia/i.test(r.region || "") || ["CN", "IN", "JP", "KR", "ID", "SG", "TW", "MY"].includes(String(r.countryFocus || "").toUpperCase())).slice(0, 10);
    if (preset === "EMERGING") {
      const mature = new Set(["US", "CA", "GB", "FR", "DE", "IT", "ES", "NL", "BE", "CH", "SE", "NO", "DK", "FI", "JP", "AU", "NZ", "EU", "NATO", "UN", "WB", "IM", "OC", "WH", "WT"]);
      return roster.filter((r) => !mature.has(String(r.countryFocus || "").toUpperCase()) && !/north america|western europe|global/i.test(r.region || "")).slice(0, 10);
    }
    return roster.slice(0, 10);
  }

  function openingPresetLimit() {
    if (state.openingPreset === "ALL") return 200;
    if (state.openingPreset === "TOP20") return 20;
    return 10;
  }

  function openingPresetLabel() {
    const labels = {
      TOP10: "Top-10 public face map",
      TOP20: "Top-20 public face map",
      ALL: "Top-200 public face map",
      EUROPE: "Top-10 Europe face map",
      NORTH_AMERICA: "Top-10 North America face map",
      ASIA: "Top-10 Asia face map",
      EMERGING: "Top-10 emerging-world face map"
    };
    return labels[state.openingPreset] || labels.TOP10;
  }

  function hasActiveSearchOrFilter() {
    return !!state.query.trim() || state.category !== "ALL" || state.country !== "ALL" || state.sector !== "ALL" || state.time !== "NOW";
  }

  function renderStartMarkers() {
    clearMap();
    const top = startList();
    const raw = top.map((r) => {
      const anchor = openingAnchorForRoster(r);
      return { roster: r, person: mappedPersonForRoster(r), trueAnchor: anchor, anchor };
    });
    const anchors = deOverlapAnchors(raw);
    if (!fallbackMode && map) {
      const bounds = [];
      for (const item of anchors) {
        const display = item.anchor;
        if (state.showHeat) drawHeat(item.trueAnchor || item.anchor, 1.1, countryColor(item.roster.countryFocus));
        const marker = L.marker([item.anchor.lat, item.anchor.lng], { icon: personDivIcon(item.roster, item.person, { label: shortName(item.roster.name) }), riseOnHover: true, keyboard: true });
        marker.on("click", () => selectRoster(item.roster.id));
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, hoverForRoster(item.roster, item.trueAnchor || item.anchor)));
        marker.on("mousemove", (e) => moveHover(e.originalEvent));
        marker.on("mouseout", hideHover);
        marker.addTo(layers.markers);
        bounds.push([item.anchor.lat, item.anchor.lng]);
      }
      drawDisplayLeaderLines(anchors);
      if (bounds.length) map.fitBounds(bounds, { padding: [54, 54], maxZoom: openingMapZoom(anchors.length), animate: true });
    } else {
      drawFallbackStart(anchors);
    }
    schedulePortraitHydration();
  }

  function drawDisplayLeaderLine(from, to, rosterItem) {
    if (!map || !from || !to || distanceKm(from, to) < 15) return;
    const pts = [[from.lat, from.lng], [to.lat, to.lng]];
    const line = L.polyline(pts, { color: "#d5dce8", weight: 1.25, opacity: .42, dashArray: "2 5", interactive: true, className: "display-leader-line" });
    line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: rosterItem.name, detail: `${from.city} → display label`, body: "The face card is offset so nearby names remain clickable; the line points back to the public anchor." }));
    line.on("mousemove", (e) => moveHover(e.originalEvent));
    line.on("mouseout", hideHover);
    line.on("click", () => selectRoster(rosterItem.id));
    line.addTo(layers.route);
  }

  function openingMapZoom(count) {
    if (state.query) return 5;
    if (count <= 10) return 4;
    if (count <= 20) return 3;
    return 2;
  }

  function selectRoster(id) {
    if (!id) return resetOpeningMap();
    if (els.quickResults) els.quickResults.hidden = true;
    const r = rosterById.get(id);
    if (!r) return;
    selectedRoster = r;
    if (els.roster) els.roster.value = r.id;
    updateRoadmovieButton(r);
    hydrateVisiblePortraits([r]);
    const p = mappedPersonForRoster(r);
    if (!p) {
      selectedPerson = null;
      timeline = [];
      currentStep = -1;
      renderProfile(null, r);
      drawProfileAnchor(r);
      els.timelineTitle.textContent = `${r.name}: profile`;
      els.timelineSummary.textContent = "No dated roadmovie has been promoted for this profile yet.";
      els.timelineCurrent.textContent = "This profile is in the top-200 roster. Public stops will appear after source review.";
      els.timelineStops.innerHTML = "";
      updateRoadmovieButton(r);
      return;
    }
    selectedPerson = p;
    buildTimeline(p, r);
    currentStep = 0;
    els.scrubber.max = Math.max(0, timeline.length - 1);
    els.scrubber.value = 0;
    renderTimelinePanel();
    renderProfile(p, r);
    renderTimelineMap({ fit: true });
    updateRoadmovieButton(r);
  }

  function startDefaultRoadmovie() {
    let target = rosterById.get(els.roster?.value || "") || selectedRoster || null;
    const q = key(els.quickSearch?.value || state.query || "");
    if (!target && q) target = roster.find((r) => rosterSearchText(r).includes(q) && mappedPersonForRoster(r)) || roster.find((r) => rosterSearchText(r).includes(q));
    if (!target) target = startList().find((r) => mappedPersonForRoster(r)) || startList()[0] || roster.find((r) => mappedPersonForRoster(r)) || roster[0];
    if (!target) return;
    const mapped = mappedPersonForRoster(target);
    selectRoster(target.id);
    updateRoadmovieButton(target);
    if (!mapped) return;
    setTimeout(() => {
      setStep(0, { pan: true, stop: true, forceRedraw: true });
      setTimeout(() => handleTimelineAction("play"), 260);
    }, 140);
  }

  function updateRoadmovieButton(target = null) {
    if (!els.roadmovieButton) return;
    const chosen = target || rosterById.get(els.roster?.value || "") || selectedRoster || null;
    const mapped = chosen ? mappedPersonForRoster(chosen) : null;
    if (chosen && mapped) {
      els.roadmovieButton.textContent = `Start ${shortName(chosen.name)} roadmovie`;
      els.roadmovieButton.classList.add("has-target");
      els.roadmovieButton.disabled = false;
    } else if (chosen) {
      els.roadmovieButton.textContent = `${shortName(chosen.name)} profile only`;
      els.roadmovieButton.classList.add("has-target");
      els.roadmovieButton.disabled = false;
    } else {
      els.roadmovieButton.textContent = "Start roadmovie";
      els.roadmovieButton.classList.remove("has-target");
      els.roadmovieButton.disabled = false;
    }
  }

  function resetOpeningMap() {
    location.hash = "";
    stopPlayback();
    state.openingPreset = "TOP10";
    if (els.openingPreset) els.openingPreset.value = "TOP10";
    if (els.roster) els.roster.value = "";
    if (els.quickSearch) els.quickSearch.value = "";
    state.query = "";
    state.category = "ALL";
    state.country = "ALL";
    state.sector = "ALL";
    state.time = "NOW";
    if (els.search) els.search.value = "";
    if (els.category) els.category.value = "ALL";
    if (els.country) els.country.value = "ALL";
    if (els.sector) els.sector.value = "ALL";
    if (els.time) els.time.value = "NOW";
    selectedPerson = null;
    selectedRoster = null;
    timeline = [];
    currentStep = -1;
    renderTop20List();
    renderOpeningMap();
    renderRankings();
    updateRoadmovieButton();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function buildTimeline(person, r) {
    const records = visibleTrailForPerson(person).sort((a, b) => new Date(a.startsAt) - new Date(b.startsAt));
    const personCalls = calls.filter((c) => (c.participantIds || []).includes(person.id));
    const base = homeBaseFor(person, r);
    const events = [
      ...records.map((rec) => ({ type: "record", date: new Date(rec.startsAt), rec })),
      ...personCalls.map((call) => ({ type: "call", date: new Date(call.startsAt), call }))
    ].filter((x) => !Number.isNaN(x.date.getTime())).sort((a, b) => a.date - b.date);

    const steps = [{
      kind: "base",
      personId: person.id,
      date: null,
      location: base,
      title: `${base.city} public base`,
      summary: `Start at ${base.city}, the public institutional anchor used for this map. It is not a private address.`,
      counterparts: [],
      status: "BASE"
    }];

    let previous = base;
    let previousDate = null;
    let previousWasPublicStop = false;
    const addReturnHome = (reasonDate, reason) => {
      if (!previous || distanceKm(previous, base) < 60) return;
      const retDate = reasonDate ? new Date(reasonDate) : (previousDate ? new Date(previousDate) : null);
      if (retDate && previousDate) retDate.setDate(retDate.getDate() + 1);
      const from = previous;
      steps.push({
        kind: "return",
        date: retDate ? retDate.toISOString() : null,
        from,
        location: base,
        title: `Return to ${base.city}`,
        summary: `${reason || "No public onward public appearance follows in this dataset"}; the trail closes at the public institutional base.`,
        counterparts: [],
        status: "STORYLINE_RETURN"
      });
      previous = base;
      previousDate = retDate || previousDate;
      previousWasPublicStop = false;
    };

    for (const item of events) {
      const date = item.date;
      const gap = previousDate ? Math.round((date - new Date(previousDate)) / DAY) : 0;
      const newTrip = previousDate && gap > 7;
      if (newTrip && previousWasPublicStop) addReturnHome(previousDate, `The next public record is ${gap} days later`);
      const from = (newTrip || previous?.city === base.city) ? base : previous;

      if (item.type === "call") {
        const otherIds = (item.call.participantIds || []).filter((id) => id !== person.id);
        steps.push({
          kind: "call",
          call: item.call,
          date: item.call.startsAt,
          from,
          location: previous || base,
          title: item.call.title || "Public call readout",
          summary: callLine(item.call, person),
          counterparts: otherIds,
          status: "CALL"
        });
        previousDate = date;
        continue;
      }

      const rec = item.rec;
      const future = isFuture(rec);
      steps.push({
        kind: future ? "future" : "stop",
        record: rec,
        date: rec.startsAt,
        from,
        location: rec.location,
        title: rec.title,
        summary: oneLine(plainEventLine(rec), 190),
        counterparts: counterpartyIdsByAppearance.get(rec.id) || [],
        status: rec.status
      });
      previous = rec.location;
      previousDate = date;
      previousWasPublicStop = !future;
    }

    if (previousWasPublicStop) addReturnHome(previousDate, "The pilot has no later public onward stop for this figure");
    timeline = steps;
    lastRenderPersonId = null;
    lastRenderStep = -1;
    visitedStepNotes.clear();
    if (els.briefingStack) els.briefingStack.innerHTML = "";
  }

  function renderTimelinePanel() {
    if (!selectedPerson) return;
    els.timelineTitle.textContent = `${selectedPerson.canonicalName}: public trail`;
    els.timelineSummary.textContent = `${timeline.length} steps. Nearby dates stay in one trip; longer gaps are shown as a dotted reset.`;
    els.timelineStops.innerHTML = timeline.map((step, idx) => {
      const date = step.date ? compactDate(step.date) : "Base";
      const city = step.location?.city || "Public anchor";
      const cps = (step.counterparts || []).slice(0, 5).map((id) => miniFace(peopleById.get(id))).join("");
      return `<button type="button" class="timeline-stop ${idx === currentStep ? "is-active" : ""} ${idx < currentStep ? "is-past" : ""}" data-step="${idx}" data-hover-title="${esc(step.title)}" data-hover-detail="${esc(textFlag(step.location?.countryCode) + " " + city)}" data-hover-body="${esc(step.summary)}"><div class="timeline-stop-head">${miniFace(selectedPerson)}<strong>${esc(date)}</strong></div><span>${flagHtml(step.location?.countryCode, step.location?.countryName)} ${esc(city)}</span><em>${esc(oneLine(step.title, 54))}</em><div class="counterparts">${cps}</div></button>`;
    }).join("");
    qsAll("[data-step]").forEach((b) => b.addEventListener("click", () => setStep(Number(b.dataset.step), { pan: true, stop: true })));
    renderCurrentStepText();
    schedulePortraitHydration();
  }

  function renderCurrentStepText() {
    const step = timeline[currentStep];
    if (!step) { els.timelineCurrent.textContent = "No public trail loaded."; return; }
    const metIds = step.counterparts || [];
    const met = metIds.map((id) => peopleById.get(id)?.canonicalName).filter(Boolean).slice(0, 6);
    const date = step.date ? compactDate(step.date) : "Base";
    const faces = metIds.slice(0, 6).map((id) => miniFace(peopleById.get(id))).join("");
    const source = stepLinks(step);
    const verb = step.kind === "call" ? "Call" : step.kind === "future" ? "Public window" : step.kind === "base" ? "Start" : "Stop";
    els.timelineCurrent.innerHTML = `
      <span class="current-face">${imageTag(selectedPerson, selectedRoster)}</span>
      <span class="current-copy">
        <strong>${esc(verb)} · ${esc(date)} · ${flagHtml(step.location?.countryCode, step.location?.countryName)} ${esc(step.location?.city || "Public anchor")}</strong>
        <span>${esc(step.summary)}</span>
        ${met.length ? `<span class="with-line"><b>Who:</b> ${esc(met.join(", "))}</span>` : `<span class="with-line"><b>Who:</b> public record does not name a counterpart in this pilot card.</span>`}
        ${faces ? `<span class="counterparts current-counterparts">${faces}</span>` : ""}
        ${source ? `<span class="source-pills">${source}</span>` : ""}
      </span>`;
    els.scrubber.value = currentStep;
    qsAll(".timeline-stop").forEach((el) => {
      const idx = Number(el.dataset.step);
      el.classList.toggle("is-active", idx === currentStep);
      el.classList.toggle("is-past", idx < currentStep);
    });
  }

  function renderTimelineMap(options = {}) {
    if (!timeline.length || !selectedPerson) return;
    const incremental = !!options.incremental && !fallbackMode && map && lastRenderPersonId === selectedPerson.id && currentStep === lastRenderStep + 1;
    if (!incremental) clearMap();
    else {
      cancelVehicleAnimation();
      layers.moving?.clearLayers?.();
      layers.vehicles?.clearLayers?.();
      layers.calls?.clearLayers?.();
    }
    const upto = timeline.slice(0, currentStep + 1);
    const bounds = [];
    if (!fallbackMode && map) {
      const startIndex = incremental ? currentStep : 0;
      if (state.showCalls && incremental) {
        for (let j = 0; j < startIndex; j++) {
          if (upto[j]?.kind === "call") drawCallForStep(upto[j], false, false);
        }
      }
      for (let i = startIndex; i < upto.length; i++) {
        const step = upto[i];
        const old = i < upto.length - 3;
        const active = i === upto.length - 1;
        if (state.showHeat && step.location) drawHeat(step.location, step.kind === "base" ? .65 : active ? 1.5 : .9, step.kind === "future" ? "#ffc247" : old ? "#8f9aaa" : countryColor(step.location.countryCode));
        if (i > 0 && state.showPaths) {
          if (step.resetFrom) drawResetLine(step.resetFrom, homeBaseFor(selectedPerson, selectedRoster), old);
          if (step.kind === "call") { if (state.showCalls) drawCallForStep(step, active, active); }
          else drawLeg({ location: step.from || upto[i - 1].location }, step, active, old);
        }
        if (incremental && i > 0) drawStop(upto[i - 1], i - 1, false, old);
        drawStop(step, i, active, old);
        if (step.location) bounds.push([step.location.lat, step.location.lng]);
      }
      drawMovingLeader(upto[upto.length - 1]);
      if (state.showLabels) drawLabels(upto);
      if (options.fit && upto.length) map.fitBounds(upto.map((s) => [s.location.lat, s.location.lng]), { padding: [70, 70], maxZoom: 5, animate: true });
    } else {
      clearMap();
      drawFallbackTimeline(upto);
    }
    lastRenderPersonId = selectedPerson.id;
    lastRenderStep = currentStep;
    els.mapTitle.textContent = selectedPerson.canonicalName;
    els.mapStatus.textContent = `Step ${currentStep + 1} of ${timeline.length}. Pause, scrub, rewind, or jump to latest.`;
    renderCurrentStepText();
    renderTimelinePanel();
  }

  function clearMap() {
    if (vehicleAnimation) { cancelAnimationFrame(vehicleAnimation); vehicleAnimation = null; }
    activeRouteLine = null;
    if (els.mapFocus) { els.mapFocus.hidden = true; els.mapFocus.innerHTML = ""; }
    if (!fallbackMode && layers.markers) Object.values(layers).forEach((layer) => layer.clearLayers?.());
    if (fallbackMode && els.fallback) {
      qsAll(".static-marker,.static-heat,.static-vehicle", els.fallback).forEach((el) => el.remove());
      const svg = qs(".static-route", els.fallback); if (svg) svg.innerHTML = "";
    }
  }

  function drawHeat(loc, weight, color) {
    if (!state.showHeat || !loc) return;
    if (!fallbackMode && map) {
      L.circleMarker([loc.lat, loc.lng], { radius: 20 + 23 * weight, color, weight: 1, opacity: .16, fillColor: color, fillOpacity: .20, interactive: false }).addTo(layers.heat);
    } else {
      const [x, y] = project(loc.lat, loc.lng);
      const d = document.createElement("div");
      d.className = "static-heat";
      d.style.left = `${x}%`;
      d.style.top = `${y}%`;
      d.style.opacity = String(Math.min(.72, .24 + weight * .18));
      els.fallback.appendChild(d);
    }
  }

  function drawDisplayLeaderLines(items) {
    if (!map || !layers.route) return;
    const used = [];
    for (const item of items) {
      const a = item.trueAnchor;
      const b = item.anchor;
      if (!a || !b || !b.shiftedForDisplay || distanceKm(a, b) < 30) continue;
      const bend = .05 + (used.length % 5) * .018;
      const pts = curvePoints(a, b, bend);
      const line = L.polyline(pts, { color: '#d7e7f8', weight: 1.4, opacity: .55, dashArray: null, className: 'display-leader-line' });
      line.on('mouseover', (e) => showHoverAt(e.originalEvent, { title: item.roster?.name || item.person?.canonicalName || 'Public figure', detail: `${a.city} anchor`, body: 'The face label is offset for readability. The line points to the public anchor.' }));
      line.on('mousemove', (e) => moveHover(e.originalEvent));
      line.on('mouseout', hideHover);
      line.on('click', () => item.roster?.id && selectRoster(item.roster.id));
      line.addTo(layers.route);
      used.push(line);
    }
  }

  function drawAnchorLeader(item, clickHandler) {
    if (!map || !layers.route || !item?.trueAnchor || !item?.anchor || !item.anchor.shiftedForDisplay) return;
    if (distanceKm(item.trueAnchor, item.anchor) < 20) return;
    const pts = curvePoints(item.trueAnchor, item.anchor, .03);
    const line = L.polyline(pts, { color: "#233246", weight: 1.6, opacity: .72, dashArray: "", className: "anchor-leader-line" });
    line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.roster?.name || "Public anchor", detail: `${item.trueAnchor.city} → display position`, body: "Leader line: the face is shifted slightly so names and portraits remain readable." }));
    line.on("mousemove", (e) => moveHover(e.originalEvent));
    line.on("mouseout", hideHover);
    if (clickHandler) line.on("click", clickHandler);
    line.addTo(layers.route);
    L.circleMarker([item.trueAnchor.lat, item.trueAnchor.lng], { radius: 3, color: "#1a2738", weight: 1, fillColor: "#ffc247", fillOpacity: .75, opacity: .9, interactive: false, className: "anchor-origin-dot" }).addTo(layers.route);
  }

  function drawLeg(prev, step, active = false, old = false) {
    if (!prev.location || !step.location || !map) return;
    if (distanceKm(prev.location, step.location) < 6) return;
    const pts = curvePoints(prev.location, step.location, step.kind === "return" ? -.12 : .16);
    const color = step.kind === "future" ? "#ffc247" : step.kind === "return" ? "#aab5c3" : old ? "#7f8793" : countryColor(step.location.countryCode || selectedPerson?.countryFocus);
    const baseOpacity = old ? .30 : step.kind === "return" ? .34 : .62;
    const opacity = active ? .18 : baseOpacity;
    const weight = active ? 2.2 : step.kind === "return" ? 1.8 : 2.4;
    const dash = step.kind === "future" ? "8 8" : step.kind === "return" ? "2 8" : null;
    const className = `route-arrow ${step.kind}${old ? " old" : ""}${active ? " active route-ghost" : ""}`;
    const line = L.polyline(pts, { color, weight, opacity, dashArray: dash, className });
    line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: legTitle(step), detail: `${prev.location.city} → ${step.location.city}`, body: step.summary }));
    line.on("mousemove", (e) => moveHover(e.originalEvent));
    line.on("mouseout", hideHover);
    line.on("click", () => setStep(timeline.indexOf(step), { pan: true, stop: true }));
    line.addTo(layers.route);
    if (active) drawVehicle(pts, prev.location, step.location, step.kind, { color, dashArray: dash, weight: step.kind === "return" ? 2.8 : 4.4 });
  }

  function drawResetLine(from, base, old = true) {
    if (!from || !base || !map || distanceKm(from, base) < 60) return;
    const pts = curvePoints(from, base, -.10);
    const line = L.polyline(pts, { color: "#9aa7b7", weight: 1.6, opacity: .30, dashArray: "2 9", className: "route-arrow return old" });
    line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: "Public-base reset", detail: `${from.city} → ${base.city}`, body: "A long gap separates the public records. The dotted line returns the trail to the public base before the next documented stop." }));
    line.on("mousemove", (e) => moveHover(e.originalEvent));
    line.on("mouseout", hideHover);
    line.addTo(layers.route);
  }

  function drawCallForStep(step, active = false, showParties = active) {
    if (!state.showCalls) return;
    const ids = step.call?.participantIds || [];
    if (ids.length < 2 || !map) return;
    const a = anchorForPersonId(ids[0]);
    const b = anchorForPersonId(ids[1]);
    if (!a || !b) return;
    const line = L.polyline([[a.lat, a.lng], [b.lat, b.lng]], { color: "#ff4d46", weight: active ? 3.4 : 2.1, opacity: active ? .92 : .44, dashArray: "3 10", className: "route-arrow call-line" });
    line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: step.title, detail: compactDate(step.date) + " · " + a.name + " ↔ " + b.name, body: step.summary }));
    line.on("mousemove", (e) => moveHover(e.originalEvent));
    line.on("mouseout", hideHover);
    line.on("click", (e) => showHoverAt(e.originalEvent, { title: step.title, detail: a.name + " ↔ " + b.name, body: step.summary }));
    line.addTo(layers.calls);
    if (active) {
      drawPhoneParty(ids[0], a, step, true, "left");
      drawPhoneParty(ids[1], b, step, true, "right");
    }
  }

  function drawPhoneParty(personId, anchor, step, active, side) {
    const p = peopleById.get(personId);
    if (!p || !anchor || !map) return;
    const r = rosterForPerson(p);
    const html = `<div class="phone-party ${active ? "is-ringing" : ""} ${esc(side)}" style="--avatar:${countryColor(p.countryFocus || anchor.countryCode)}"><span class="phone-face">${imageTag(p, r)}</span>${entityBadgeHtml(p, p.countryFocus || anchor.countryCode, p.countryName || anchor.countryName)}<span class="phone-ring">☎</span><b>${esc(shortName(p.canonicalName))}</b></div>`;
    const marker = L.marker([anchor.lat, anchor.lng], { icon: L.divIcon({ className: "", html, iconSize: [100, 58], iconAnchor: [50, 29] }), riseOnHover: true, keyboard: true });
    marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: p.canonicalName, detail: `${compactDate(step.date)} phone call`, body: step.summary }));
    marker.on("mousemove", (e) => moveHover(e.originalEvent));
    marker.on("mouseout", hideHover);
    marker.on("click", () => selectRoster(r?.id));
    marker.addTo(layers.moving);
  }

  function drawVehicle(points, from, to, kind = "stop", style = {}) {
    if (!points?.length || !layers.vehicles) return;
    const icon = kind === "future" ? "✈" : transportIcon(from, to);
    const color = style.color || (kind === "future" ? "#ffc247" : "#8ec7ff");
    const vapor = L.polyline([points[0]], { color: "#ffffff", weight: 7.8, opacity: .18, dashArray: "2 10", className: "vehicle-vapor" }).addTo(layers.vehicles);
    const trail = L.polyline([points[0]], { color, weight: style.weight || 4.4, opacity: .88, dashArray: style.dashArray || null, className: `vehicle-contrail ${kind}` }).addTo(layers.vehicles);
    const marker = L.marker(points[0], { icon: L.divIcon({ className: "", html: `<div class="vehicle-chip">${icon}</div>`, iconSize: [42, 32], iconAnchor: [21, 16] }), interactive: false }).addTo(layers.vehicles);
    const duration = speed === 1 ? 5600 : speed === 2 ? 3600 : 2300;
    const delay = speed === 1 ? 1200 : 650;
    const startAt = performance.now() + delay;
    const animate = (t) => {
      if (t < startAt) { vehicleAnimation = requestAnimationFrame(animate); return; }
      const progress = Math.min(1, (t - startAt) / duration);
      const eased = progress < .5 ? 2 * progress * progress : 1 - Math.pow(-2 * progress + 2, 2) / 2;
      const idx = Math.min(points.length - 1, Math.floor(eased * (points.length - 1)));
      const travelled = points.slice(0, Math.max(2, idx + 1));
      marker.setLatLng(points[idx]);
      trail.setLatLngs(travelled);
      vapor.setLatLngs(travelled);
      if (progress < 1) vehicleAnimation = requestAnimationFrame(animate);
      else {
        trail.setLatLngs(points);
        vapor.setLatLngs(points);
        vehicleAnimation = null;
      }
    };
    vehicleAnimation = requestAnimationFrame(animate);
  }

  function cancelVehicleAnimation() {
    if (vehicleAnimation) { cancelAnimationFrame(vehicleAnimation); vehicleAnimation = null; }
  }

  function updateMapFocus(step) {
    if (!els.mapFocus) return;
    if (!step || !selectedPerson) {
      els.mapFocus.hidden = true;
      els.mapFocus.innerHTML = "";
      return;
    }
    const r = selectedRoster || rosterForPerson(selectedPerson);
    const loc = step.location || homeBaseFor(selectedPerson, r);
    const date = step.date ? compactDate(step.date) : "Base";
    const label = step.kind === "call" ? "Phone call" : step.kind === "future" ? "Future public window" : step.kind === "return" ? "Return" : step.kind === "base" ? "Public base" : "Current stop";
    els.mapFocus.innerHTML = `
      <button type="button" class="map-focus-inner" aria-label="Open ${esc(selectedPerson.canonicalName)} profile">
        <span class="focus-photo">${imageTag(selectedPerson, r)}</span>
        <span class="focus-copy"><strong>${esc(shortName(selectedPerson.canonicalName))}</strong><em>${esc(label)} · ${esc(date)} · ${flagHtml(loc.countryCode, loc.countryName)} ${esc(loc.city || "Public anchor")}</em><small>${esc(oneLine(step.title || step.summary || "Public record", 88))}</small></span>
      </button>`;
    els.mapFocus.hidden = false;
    const button = qs(".map-focus-inner", els.mapFocus);
    button?.addEventListener("click", () => renderProfile(selectedPerson, r));
    button?.addEventListener("pointerover", (ev) => showHoverAt(ev, { title: selectedPerson.canonicalName, detail: `${date} · ${loc.city}`, body: step.summary || step.title || "Public record." }));
    button?.addEventListener("pointermove", moveHover);
    button?.addEventListener("pointerout", hideHover);
  }

  function drawStop(step, idx, active = false, old = false) {
    if (!step.location || !map) return;
    const icon = stopIcon(step);
    const cls = `stop-marker ${esc(step.kind)}${active ? " current" : ""}${old ? " old" : ""}`;
    const face = selectedPerson && !active ? `<span class="stop-photo">${imageTag(selectedPerson, selectedRoster)}</span>` : "";
    const html = `<div class="${cls}" title="${esc(step.title)}">${face}<span class="stop-symbol">${icon}</span><span class="stop-flag">${flagHtml(step.location.countryCode, step.location.countryName)}</span></div>`;
    const size = active ? [46, 46] : [38, 38];
    const marker = L.marker([step.location.lat, step.location.lng], { icon: L.divIcon({ className: "", html, iconSize: size, iconAnchor: [size[0] / 2, size[1] / 2] }), riseOnHover: true, keyboard: true });
    marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: step.title, detail: `${flagEmoji(step.location.countryCode)} ${step.location.city} · ${step.date ? compactDate(step.date) : "base"}`, body: step.summary }));
    marker.on("mousemove", (e) => moveHover(e.originalEvent));
    marker.on("mouseout", hideHover);
    marker.on("click", () => setStep(idx, { pan: true, stop: true }));
    marker.addTo(active ? layers.moving : layers.markers);
  }

  function drawMovingLeader(step) {
    if (!selectedPerson || !step?.location || !map) return;
    updateMapFocus(step);
  }

  function drawLabels(steps) {
    const placed = [];
    for (const step of steps.slice(-5)) {
      if (!step.location) continue;
      const pt = map.latLngToContainerPoint([step.location.lat, step.location.lng]);
      const box = { x: pt.x + 15, y: pt.y - 12, w: 150, h: 30 };
      if (placed.some((b) => overlaps(b, box))) continue;
      placed.push(box);
      L.marker([step.location.lat, step.location.lng], { icon: L.divIcon({ className: "", html: `<div class="map-label">${esc(compactDate(step.date || now))} · ${esc(step.location.city)}</div>`, iconSize: [150, 28], iconAnchor: [-16, 14] }), interactive: false }).addTo(layers.labels);
    }
  }

  function drawCallLines(allowedIds = null, untilDate = null) {
    if (!state.showCalls || !map || !layers.calls) return;
    const cutoff = untilDate ? new Date(untilDate) : null;
    for (const call of calls) {
      const ids = call.participantIds || [];
      if (ids.length < 2) continue;
      if (allowedIds && !ids.some((id) => allowedIds.has(id))) continue;
      if (cutoff && call.startsAt && new Date(call.startsAt) > cutoff) continue;
      const a = anchorForPersonId(ids[0]);
      const b = anchorForPersonId(ids[1]);
      if (!a || !b) continue;
      const line = L.polyline([[a.lat, a.lng], [b.lat, b.lng]], { color: "#ff5b55", weight: 2.2, opacity: .74, dashArray: "3 9", className: "route-arrow call-line" });
      line.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: call.title || "Public call", detail: `${compactDate(call.startsAt)} · ${a.name} ↔ ${b.name}`, body: call.summary || "Published call readout." }));
      line.on("mousemove", (e) => moveHover(e.originalEvent));
      line.on("mouseout", hideHover);
      line.on("click", (e) => showHoverAt(e.originalEvent, { title: call.title || "Public call", detail: `${a.name} ↔ ${b.name}`, body: call.summary || "Published call readout." }));
      line.addTo(layers.calls);
    }
  }

  function anchorForPersonId(id) {
    const p = peopleById.get(id);
    if (!p) return null;
    const r = rosterForPerson(p);
    const base = homeBaseFor(p, r);
    return { ...base, name: p.canonicalName };
  }

  function drawProfileAnchor(r) {
    updateMapFocus(null);
    clearMap();
    if (els.mapFocus) els.mapFocus.hidden = true;
    const anchor = latestAnchorForRoster(r);
    els.mapTitle.textContent = r.name;
    els.mapStatus.textContent = "Profile anchor. Dated trips appear when public records are approved.";
    if (!fallbackMode && map) {
      drawHeat(anchor, 1.1, countryColor(anchor.countryCode));
      const marker = L.marker([anchor.lat, anchor.lng], { icon: personDivIcon(r, null, { label: shortName(r.name) }), riseOnHover: true, keyboard: true });
      marker.on("mouseover", (e) => showHoverAt(e.originalEvent, hoverForRoster(r, anchor)));
      marker.on("mouseout", hideHover);
      marker.addTo(layers.markers);
      map.setView([anchor.lat, anchor.lng], 4, { animate: true });
    } else {
      drawFallbackStart([{ roster: r, person: null, anchor }]);
    }
  }

  function drawFallbackStart(items) {
    clearMap();
    for (const item of items) {
      drawHeat(item.anchor, 1, countryColor(item.anchor.countryCode));
      const marker = document.createElement("button");
      marker.className = "static-marker";
      marker.style.left = `${project(item.anchor.lat, item.anchor.lng)[0]}%`;
      marker.style.top = `${project(item.anchor.lat, item.anchor.lng)[1]}%`;
      marker.innerHTML = markerHtml(item.roster, item.person, shortName(item.roster.name));
      marker.addEventListener("click", () => selectRoster(item.roster.id));
      marker.addEventListener("pointerover", (e) => showHoverAt(e, hoverForRoster(item.roster, item.anchor)));
      marker.addEventListener("pointerout", hideHover);
      els.fallback.appendChild(marker);
    }
  }

  function drawFallbackTimeline(steps) {
    const svg = qs(".static-route", els.fallback);
    for (let i = 0; i < steps.length; i++) {
      const s = steps[i];
      drawHeat(s.location, i === steps.length - 1 ? 1.5 : .8, s.kind === "future" ? "#ffc247" : countryColor(s.location?.countryCode));
      if (i > 0) {
        const prev = steps[i - 1];
        const p0 = project(prev.location.lat, prev.location.lng);
        const p1 = project(s.location.lat, s.location.lng);
        const mx = (p0[0] + p1[0]) / 2;
        const my = (p0[1] + p1[1]) / 2 - 12;
        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
        path.setAttribute("d", `M${p0[0] * 10} ${p0[1] * 5} Q${mx * 10} ${my * 5} ${p1[0] * 10} ${p1[1] * 5}`);
        path.setAttribute("fill", "none");
        path.setAttribute("stroke", s.kind === "future" ? "#ffc247" : s.kind === "return" ? "#9ba6b5" : "#72bfff");
        path.setAttribute("stroke-width", s.kind === "return" ? "1.2" : "2.6");
        path.setAttribute("stroke-dasharray", s.kind === "return" ? "2 5" : s.kind === "future" ? "7 6" : "");
        path.setAttribute("opacity", s.kind === "return" ? ".45" : ".8");
        svg.appendChild(path);
      }
      const marker = document.createElement("button");
      marker.className = "static-marker";
      marker.style.left = `${project(s.location.lat, s.location.lng)[0]}%`;
      marker.style.top = `${project(s.location.lat, s.location.lng)[1]}%`;
      marker.innerHTML = i === steps.length - 1 ? `<div class="moving-chip"><span class="moving-photo">${imageTag(selectedPerson, selectedRoster)}</span>${entityBadgeHtml(selectedPerson, selectedPerson?.countryFocus || s.location.countryCode, selectedRoster?.countryName)}</div>` : `<div class="stop-marker ${esc(s.kind)}"><span class="stop-icon">${stopIcon(s)}</span>${flagBadgeHtml(s.location.countryCode, s.location.countryName)}</div>`;
      marker.addEventListener("click", () => setStep(timeline.indexOf(s), { pan: true, stop: true }));
      marker.addEventListener("pointerover", (e) => showHoverAt(e, { title: s.title, detail: `${textFlag(s.location.countryCode)} ${s.location.city}`, body: s.summary }));
      marker.addEventListener("pointerout", hideHover);
      els.fallback.appendChild(marker);
    }
  }


  function showStepBrief(step) {
    if (!els.stepBrief || !step || !selectedPerson) return;
    if (stepBriefTimer) clearTimeout(stepBriefTimer);
    els.stepBrief.innerHTML = stepBriefHtml(step, true);
    els.stepBrief.hidden = false;
    qsAll("a", els.stepBrief).forEach((a) => a.addEventListener("click", (e) => e.stopPropagation()));
    stepBriefTimer = setTimeout(() => { if (els.stepBrief) els.stepBrief.hidden = true; }, 5000);
  }

  function addBriefingCard(step, index) {
    if (!els.briefingStack || !step || index < 0) return;
    const keyValue = `${selectedPerson?.id || "person"}-${index}`;
    if (visitedStepNotes.has(keyValue)) return;
    visitedStepNotes.set(keyValue, true);
    const card = document.createElement("article");
    card.className = "briefing-card";
    card.innerHTML = stepBriefHtml(step, false);
    card.querySelectorAll("button[data-jump-step]").forEach((b) => b.addEventListener("click", () => setStep(Number(b.dataset.jumpStep), { pan: true, stop: true })));
    const jump = document.createElement("button");
    jump.type = "button";
    jump.className = "source-link jump-link";
    jump.dataset.jumpStep = String(index);
    jump.textContent = "show on map";
    jump.addEventListener("click", () => setStep(index, { pan: true, stop: true }));
    card.appendChild(jump);
    els.briefingStack.prepend(card);
  }

  function stepBriefHtml(step, temporary) {
    const date = step.date ? compactDate(step.date) : "Public base";
    const loc = step.location ? `${flagHtml(step.location.countryCode, step.location.countryName)} ${esc(step.location.city)}` : "Public anchor";
    const who = step.kind === "call" ? callParticipants(step.call) : step.counterparts?.length ? step.counterparts.map((id) => peopleById.get(id)?.canonicalName).filter(Boolean).join(", ") : selectedPerson?.canonicalName || "Public record";
    const faces = step.kind === "call" ? callParticipantFaces(step.call) : (step.counterparts || []).slice(0, 8).map((id) => miniFace(peopleById.get(id))).join("");
    const icon = eventIcon(step);
    const links = stepLinks(step);
    const title = step.kind === "return" ? `Back to ${step.location?.city || "public base"}` : step.title;
    return `<div class="brief-head"><span class="brief-icon">${esc(icon)}</span><div><strong>${esc(date)} · ${loc}</strong><span>${esc(oneLine(title, 90))}</span></div></div><p>${esc(step.summary || "Public record.")}</p><div class="brief-who"><b>${step.kind === "call" ? "Call" : "Who"}:</b> ${esc(who || "not named in this card")}</div>${faces ? `<div class="counterparts brief-faces">${faces}</div>` : ""}<div class="source-pills">${links}</div>${temporary ? `<em class="brief-timer">This note closes in five seconds. It remains in the briefing notes below.</em>` : ""}`;
  }

  function eventIcon(step) {
    if (!step) return "•";
    if (step.kind === "call") return "☎";
    if (step.kind === "return") return "↩";
    if (step.kind === "future") return "✦";
    const text = [step.title, step.record?.eventType, step.record?.topics?.join(" ")].join(" ").toLowerCase();
    if (text.includes("summit") || text.includes("g7") || text.includes("g20") || text.includes("nato")) return "♜";
    if (text.includes("bilateral") || text.includes("meet")) return "◆";
    if (text.includes("speech") || text.includes("address")) return "◉";
    if (text.includes("forum") || text.includes("conference")) return "▣";
    return "•";
  }

  function callParticipants(call) {
    return (call?.participantIds || []).map((id) => peopleById.get(id)?.canonicalName).filter(Boolean).join(" and ");
  }

  function callParticipantFaces(call) {
    return (call?.participantIds || []).map((id) => miniFace(peopleById.get(id))).join("");
  }

  function newsSearchLink(step) {
    const q = encodeURIComponent([selectedPerson?.canonicalName, step?.title, step?.location?.city, step?.date ? compactDate(step.date) : ""].filter(Boolean).join(" "));
    if (!q) return "";
    return `<a class="source-link newspaper" href="https://news.google.com/search?q=${q}" target="_blank" rel="noreferrer">news</a>`;
  }

  function handleTimelineAction(action) {
    if (!timeline.length) { startDefaultRoadmovie(); return; }
    if (action === "play") return playing ? pausePlayback() : playTimeline();
    if (action === "stop") return stopPlayback();
    if (action === "restart") return setStep(0, { pan: true, stop: true });
    if (action === "back") return setStep(currentStep - 1, { pan: true, stop: true });
    if (action === "next") return setStep(currentStep + 1, { pan: true, stop: true });
    if (action === "back5") return setStep(currentStep - 5, { pan: true, stop: true });
    if (action === "next5") return setStep(currentStep + 5, { pan: true, stop: true });
    if (action === "latest") return setStep(timeline.length - 1, { pan: true, stop: true, fitEnd: true });
    if (action === "speed") {
      speed = speed === 1 ? 2 : speed === 2 ? 4 : 1;
      els.speedToggle.textContent = `${speed}×`;
      els.speedToggle.classList.toggle("is-fast", speed > 1);
      if (playing) { pausePlayback(); playTimeline(); }
    }
  }

  function playTimeline() {
    playing = true;
    els.playToggle.textContent = "Pause";
    els.playToggle.classList.add("is-playing");
    const tick = () => {
      if (!playing) return;
      if (currentStep >= timeline.length - 1) { pausePlayback(); setTimeout(fitTimelineBounds, 750); return; }
      setStep(currentStep + 1, { pan: true, incremental: true });
      playTimer = setTimeout(tick, speed === 1 ? 6200 : speed === 2 ? 3600 : 2100);
    };
    playTimer = setTimeout(tick, 520);
  }

  function pausePlayback() {
    playing = false;
    clearTimeout(playTimer);
    els.playToggle.textContent = "Play";
    els.playToggle.classList.remove("is-playing");
  }

  function stopPlayback() { pausePlayback(); cancelVehicleAnimation(); }

  function setStep(index, opts = {}) {
    if (!timeline.length) return;
    const previousIndex = currentStep;
    const target = clamp(index, 0, timeline.length - 1);
    if (opts.stop) pausePlayback();
    currentStep = target;
    const incremental = !!opts.incremental && target === previousIndex + 1 && !opts.forceRedraw;
    const render = () => {
      renderTimelineMap({ incremental });
      addBriefingCard(timeline[currentStep], currentStep);
      setTimeout(() => showStepBrief(timeline[currentStep]), opts.pan ? 720 : 120);
    };
    if (opts.pan && !fallbackMode && map) focusStep(target);
    if (opts.pan && incremental) setTimeout(render, 980); else render();
    if (opts.fitEnd || currentStep === timeline.length - 1) setTimeout(fitTimelineBounds, 1800);
  }

  function focusStep(index) {
    if (!map || !timeline.length) return;
    const step = timeline[index];
    const from = step?.from || timeline[index - 1]?.location;
    if (!step?.location) return;
    if (step.kind === "call") {
      const ids = step.call?.participantIds || [];
      const anchors = ids.map(anchorForPersonId).filter(Boolean);
      if (anchors.length >= 2) {
        map.flyToBounds(anchors.map((a) => [a.lat, a.lng]), { padding: [110, 110], maxZoom: 4, duration: 1.45 });
        return;
      }
    }
    if (from && distanceKm(from, step.location) >= 6) {
      const d = distanceKm(from, step.location);
      const maxZoom = d < 80 ? 9 : d < 320 ? 7 : d < 1200 ? 5 : 3;
      map.flyToBounds([[from.lat, from.lng], [step.location.lat, step.location.lng]], { padding: [120, 120], maxZoom, duration: 1.45 });
    } else {
      map.flyTo([step.location.lat, step.location.lng], 5, { duration: 1.2 });
    }
  }

  function fitTimelineBounds() {
    if (!map || !timeline.length) return;
    const bounds = timeline.map((s) => s.location ? [s.location.lat, s.location.lng] : null).filter(Boolean);
    if (bounds.length) map.fitBounds(bounds, { padding: [66, 66], maxZoom: 5, animate: true });
  }

  function renderTop20List() {
    const list = startList();
    if (els.startListTitle) els.startListTitle.textContent = hasActiveSearchOrFilter() ? `Matches (${list.length})` : openingPresetLabel().replace(" public face map", "");
    if (els.startListHelp) els.startListHelp.textContent = hasActiveSearchOrFilter() ? "Search and filters cover the full top-200 roster." : "Click a name or face. The roadmovie button follows the selected profile.";
    els.top20.innerHTML = list.length ? list.map((r) => {
      const p = mappedPersonForRoster(r);
      const anchor = openingAnchorForRoster(r);
      return `<button type="button" class="top20-chip" data-roster-id="${esc(r.id)}" data-hover-title="${esc(r.name)}" data-hover-detail="${esc((r.bucket || r.roleTitle) + " · " + anchor.city)}" data-hover-body="${esc(anchor.countryName || r.countryName)}"><span class="avatar" style="--avatar:${countryColor(r.countryFocus)}">${imageTag(p || r, r)}${entityBadgeHtml(p || r, r.countryFocus, r.countryName)}</span><span><strong>${esc(r.name)}</strong><span>${esc(anchor.city)} · ${esc(r.bucket || r.roleTitle)}</span></span></button>`;
    }).join("") : `<div class="empty-note">No top-200 match. Try another spelling.</div>`;
    qsAll("[data-roster-id]", els.top20).forEach((button) => button.addEventListener("click", () => selectRoster(button.dataset.rosterId)));
    schedulePortraitHydration();
  }

  function renderQuickResults(input) {
    if (!els.quickResults) return;
    const q = key(input);
    if (!q) { els.quickResults.hidden = true; els.quickResults.innerHTML = ""; return; }
    const results = roster.filter((r) => rosterSearchText(r).includes(q)).slice(0, 24);
    els.quickResults.innerHTML = results.length ? results.map((r) => {
      const p = mappedPersonForRoster(r);
      return `<button type="button" class="quick-hit" data-quick-id="${esc(r.id)}" data-hover-title="${esc(r.name)}" data-hover-detail="${esc(r.countryName || "Global")}" data-hover-body="${esc(r.bucket || r.roleTitle)}"><span class="avatar" style="--avatar:${countryColor(r.countryFocus)}">${imageTag(p || r, r)}${entityBadgeHtml(p || r, r.countryFocus, r.countryName)}</span><span><strong>${esc(r.name)}</strong><span>${esc(r.bucket || r.roleTitle)} · ${esc(r.countryName || "Global")}</span></span><em>${mappedPersonForRoster(r) ? "trail" : "profile"}</em></button>`;
    }).join("") : `<div class="quick-empty">No top-200 match.</div>`;
    qsAll("[data-quick-id]", els.quickResults).forEach((b) => b.addEventListener("click", () => selectRoster(b.dataset.quickId)));
    els.quickResults.hidden = false;
    schedulePortraitHydration();
  }


  function rosterSearchText(r) {
    return key([r.name, r.canonicalName, r.countryName, r.countryFocus, r.bucket, r.roleTitle, r.organization, r.region, r.sector, r.slug, r.wikiTitle].join(" "));
  }

  function renderProfile(p, r) {
    const person = p || mappedPersonForRoster(r) || null;
    const subject = person || r;
    if (!subject) return;
    const rosterItem = r || rosterForPerson(person) || subject;
    const anchor = latestAnchorForRoster(rosterItem);
    const records = person ? visibleTrailForPerson(person) : [];
    const last = records.filter((a) => !isFuture(a)).at(-1);
    const next = records.find((a) => isFuture(a));
    const lines = profileLineObjects(subject, person, rosterItem, records, anchor, last, next);
    els.profile.innerHTML = `
      <div class="profile-top">
        <span class="avatar" style="--avatar:${countryColor(subject.countryFocus || anchor.countryCode)}">${imageTag(subject, rosterItem)}${entityBadgeHtml(subject, subject.countryFocus || anchor.countryCode, subject.countryName || anchor.countryName)}</span>
        <div><h3>${esc(subject.canonicalName || subject.name)}</h3><p>${esc(subject.roleTitle || subject.bucket || "Public figure")}</p></div>
      </div>
      <div class="pills"><span class="pill">${orgOrRoleBadge(subject)} ${esc(subject.sector || subject.bucket || "public life")}</span><span class="pill">${esc(ageLine(subject))}</span><span class="pill">${records.length} public records</span><span class="pill">${esc(subject.countryName || anchor.countryName || "Global")}</span></div>
      <div class="profile-lines">${lines.map((line) => `<div class="profile-line" data-hover-title="${esc(line.label)}" data-hover-detail="${esc(subject.canonicalName || subject.name)}" data-hover-body="${esc(line.text)}"><span class="line-icon">${esc(line.icon)}</span><strong>${esc(line.label)}</strong><p>${esc(line.text)}</p></div>`).join("")}</div>
      <div class="profile-social"><strong>Links</strong><div class="source-pills">${socialLinksHtml(subject, person, last)}</div></div>`;
    schedulePortraitHydration();
  }


  function profileLineObjects(subject, person, rosterItem, records, anchor, last, next) {
    const org = subject.organization || rosterItem?.organization || subject.bucket || "public institution";
    const role = subject.roleTitle || subject.bucket || rosterItem?.bucket || "public figure";
    const name = subject.canonicalName || subject.name || rosterItem?.name || "This profile";
    const sector = subject.sector || rosterItem?.sector || "public life";
    const cities = [...new Set(records.map((a) => a.location?.city).filter(Boolean))].slice(0, 7);
    const countries = [...new Set(records.map((a) => a.location?.countryName || countryNameFromCode(a.location?.countryCode)).filter(Boolean))].slice(0, 6);
    const topics = [...new Set(records.flatMap((a) => a.topics || []).filter(Boolean))].slice(0, 7);
    const counterpartNames = [...new Set(records.flatMap((a) => counterpartyIdsByAppearance.get(a.id) || []).map((id) => peopleById.get(id)?.canonicalName).filter(Boolean))].slice(0, 6);
    const futureCount = records.filter(isFuture).length;
    const lines = [
      { icon: "👤", label: "Role", text: `${name} is followed as ${role}.` },
      { icon: "🏛", label: "Institution", text: `${org}. Sector lens: ${sector}.` },
      { icon: "📍", label: "Public base", text: `${anchor.city}, ${anchor.countryName}. Used only as a public institutional anchor.` },
      { icon: "🗺", label: "Trail", text: records.length ? `${records.length} dated public records are available in this build.` : "No dated public trail is visible yet; the profile remains searchable." },
      { icon: "🌐", label: "Cities", text: cities.length ? `Visible stops include ${cities.join(", ")}.` : "No city-level public stops are visible yet." },
      { icon: "🏳", label: "Countries", text: countries.length ? `Mapped spread: ${countries.join(", ")}.` : `${subject.countryName || anchor.countryName || "Global"} is the main public anchor.` },
      { icon: "🤝", label: "Network", text: counterpartNames.length ? `Public cards connect this profile with ${counterpartNames.join(", ")}.` : "Relationship edges appear once a public meeting, panel or call readout names another person." },
      { icon: "🧭", label: "Why follow", text: profileRelevanceLine(subject, role, sector) },
      { icon: "🔎", label: "Themes", text: topics.length ? `Current record themes: ${topics.join(", ")}.` : themeLineFor(subject) },
      { icon: "🗣", label: "Latest", text: last ? `${compactDate(last.startsAt)} in ${last.location.city}: ${plainEventLine(last)}` : "No dated public record is visible yet." },
      { icon: "📅", label: "Next", text: next ? `${compactDate(next.startsAt)} in ${next.location.city}: ${oneLine(next.title, 120)}` : futureCount ? `${futureCount} future public windows are listed.` : "No announced future public window in the current build." },
      { icon: "👁", label: "Where to watch", text: crawlerFocusLine(subject, role, sector) }
    ];
    return lines;
  }

  function profileRelevanceLine(subject, role, sector) {
    const hay = [role, sector, subject.bucket, subject.organization, subject.countryName].join(" ").toLowerCase();
    if (/central bank|monetary|finance|imf|bis|world bank|asset|bank/.test(hay)) return "Signals can move expectations around rates, liquidity, debt, bank regulation and capital allocation.";
    if (/technology|ai|software|semiconductor|cloud/.test(hay)) return "Public appearances can point to AI, chips, cloud, regulation, defence technology and investment priorities.";
    if (/energy|opec|oil|gas|climate/.test(hay)) return "Useful for energy security, supply discipline, transition finance and industrial policy.";
    if (/security|nato|defence|foreign|state|government|president|prime/.test(hay)) return "Useful for diplomacy, sanctions, defence posture, trade and coalition-building.";
    if (/royal/.test(hay)) return "Royal engagements often show state priorities, soft power and institutional relationships.";
    return "Useful when a public appearance connects policy, capital, diplomacy or sector attention.";
  }

  function themeLineFor(subject) {
    const hay = [subject.sector, subject.bucket, subject.organization, subject.roleTitle].join(" ");
    if (/central|monetary|bank|finance/i.test(hay)) return "Watch speeches, panels, G30, BIS, IMF and central-bank calendars.";
    if (/technology|business/i.test(hay)) return "Watch Davos, AI summits, Sun Valley, Milken and public company events.";
    if (/energy|opec/i.test(hay)) return "Watch CERAWeek, ADIPEC, OPEC windows and Gulf investment forums.";
    return "Watch summits, speeches, public readouts and host-event participant lists.";
  }

  function crawlerFocusLine(subject, role, sector) {
    const hay = [role, sector, subject.bucket, subject.organization].join(" ").toLowerCase();
    if (/central bank|monetary/.test(hay)) return "Best public signals: speech pages, policy calendars, Jackson Hole, Sintra, BIS, IMF and university appearances.";
    if (/technology|business|finance/.test(hay)) return "Best public signals: conference programmes, investor forums, university keynotes and company newsrooms.";
    if (/international|un|oecd|imf|world bank|wto|who|gavi/.test(hay)) return "Best public signals: institutional calendars, speeches, ministerial pages and multilateral programmes.";
    return "Best public signals: official calendars, host pages, speeches, summit programmes and public readouts.";
  }

  function socialLinksHtml(subject, person, last) {
    const links = socialLinksFor(subject);
    const pills = [];
    if (links.official) pills.push(sourcePill(links.official, "official"));
    if (links.wikipedia) pills.push(sourcePill(links.wikipedia, "profile"));
    if (links.wikidata) pills.push(sourcePill(links.wikidata, "Wikidata"));
    if (links.linkedinSearch) pills.push(sourcePill(links.linkedinSearch, "LinkedIn"));
    if (links.socialSearch) pills.push(sourcePill(links.socialSearch, "official social"));
    if (last) pills.push(stepLinks({ record: last }));
    return pills.filter(Boolean).join("") || "Links pending.";
  }


  function socialLinksFor(subject) {
    const s = subject?.socialLinks || {};
    const name = encodeURIComponent(subject?.canonicalName || subject?.name || "");
    const org = encodeURIComponent(subject?.organization || subject?.countryName || "");
