  function topicRowsForPanels() {
    const rows = topicFamilies().map((t) => {
      const apps = appearances.filter((a) => topicsForRecord(a).includes(t.name) || t.rx.test(recordHay(a)));
      const agendas = uniqueAgendas(eventAgendas).filter((a) => topicsForRecord(a).includes(t.name) || t.rx.test(agendaHay(a)));
      const peopleSet = new Set(apps.map((a)=>a.personId));
      agendas.flatMap((a)=>peopleFromNames(a.participantNames || [])).forEach((p)=>peopleSet.add(p.id));
      const monthValues = Array.from({ length: 6 }, (_, i) => {
        const start = new Date(now.getFullYear(), now.getMonth() - (5 - i), 1);
        const end = new Date(now.getFullYear(), now.getMonth() - (4 - i), 1);
        return apps.filter((a) => new Date(a.startsAt) >= start && new Date(a.startsAt) < end).length + agendas.filter((a) => new Date(a.startsAt) >= start && new Date(a.startsAt) < end).length;
      });
      const growth = monthValues.at(-1) - Math.round(monthValues.slice(0, 3).reduce((a,b)=>a+b,0) / 3);
      return { ...t, apps, agendas, count: apps.length + agendas.length * 2, growth, monthValues, people: [...peopleSet].map((id)=>peopleById.get(id)).filter(Boolean) };
    }).filter((t)=>t.count > 0).sort((a,b)=>b.count-a.count);
