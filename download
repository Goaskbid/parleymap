  async function hydrateVisiblePortraits(list) {
    const missing = (list || []).filter((r) => !r.imageUrl && r.wikiTitle && !hydratedPortraitIds.has(r.id));
    if (!missing.length) return;
    missing.forEach((r) => hydratedPortraitIds.add(r.id));
    const batches = [];
    for (let i = 0; i < missing.length; i += 40) batches.push(missing.slice(i, i + 40));
    for (const batch of batches) {
      try {
        const params = new URLSearchParams({
          action: "query",
          origin: "*",
          format: "json",
          redirects: "1",
          prop: "pageimages",
          piprop: "thumbnail",
          pithumbsize: "220",
          titles: batch.map((r) => r.wikiTitle).join("|")
        });
        const res = await fetch(`https://en.wikipedia.org/w/api.php?${params.toString()}`);
        if (!res.ok) continue;
        const json = await res.json();
        const byTitle = new Map();
        batch.forEach((r) => {
          byTitle.set(key(r.wikiTitle), r);
          byTitle.set(key(String(r.wikiTitle || "").replaceAll("_", " ")), r);
          byTitle.set(key(r.name), r);
          byTitle.set(key(r.canonicalName), r);
        });
        (json.query?.normalized || []).forEach((n) => {
          const r = byTitle.get(key(n.from));
          if (r) byTitle.set(key(n.to), r);
        });
        (json.query?.redirects || []).forEach((n) => {
          const r = byTitle.get(key(n.from));
          if (r) byTitle.set(key(n.to), r);
        });
        Object.values(json.query?.pages || {}).forEach((page) => {
          const url = cleanPortraitUrl(page?.thumbnail?.source || "");
          const r = byTitle.get(key(page?.title));
          if (!url || !r || badPortraitUrl(url, r.name)) return;
          r.imageUrl = url;
          portraitByTitle.set(key(page.title), url);
          portraitByTitle.set(key(r.wikiTitle), url);
          portraitByTitle.set(key(r.name), url);
          portraitByTitle.set(key(r.canonicalName), url);
          const p = mappedPersonForRoster(r);
          if (p && !p.imageUrl) p.imageUrl = url;
        });
      } catch (_) {}
    }
    renderTop20List();
    renderRankings();
    if (els.quickSearch?.value) renderQuickResults(els.quickSearch.value);
    if (!selectedPerson) renderStartMarkers(); else renderTimelineMap({ keepView: true });
    if (selectedPerson || selectedRoster) renderProfile(selectedPerson, selectedRoster);
    schedulePortraitHydration();
  }

