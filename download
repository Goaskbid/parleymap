    }
    const groups = [...merged.values()].sort((a, b) => Math.abs(daysFromNow(a.date)) - Math.abs(daysFromNow(b.date))).slice(0, 12);
    els.summitPills.innerHTML = groups.length ? groups.map((g) => {
      const names = g.people.slice(0, 5).map((p) => shortName(p.canonicalName)).join(", ");
      const faces = g.people.slice(0, 6).map((p) => miniFace(p)).join("");
      const label = oneLine(cleanEventTitle(g.title), 34);
      const body = g.itemType === "agenda" ? g.why : (names ? "Public cards include: " + names + ". " : "") + "Click to focus this public event window.";
      return `<button type="button" class="summit-pill" data-summit-key="${esc(g.key)}" data-summit-type="${esc(g.itemType)}" data-hover-title="${esc(cleanEventTitle(g.title))}" data-hover-detail="${esc(compactDate(g.date) + " · " + g.location.city)}" data-hover-body="${esc(body)}"><span class="summit-icon">${esc(stopIcon({ kind: "future", title: g.title }))}</span><strong>${esc(label)}</strong><em>${esc(compactDate(g.date))} · ${flagHtml(g.location.countryCode, g.location.countryName)} ${esc(g.location.city)}</em><span class="summit-faces">${faces}</span></button>`;
    }).join("") : `<span class="summit-empty">No announced public summit windows in this build.</span>`;
    qsAll("[data-summit-key]", els.summitPills).forEach((b) => b.addEventListener("click", () => b.dataset.summitType === "agenda" ? focusAgenda(b.dataset.summitKey) : focusSummit(b.dataset.summitKey)));
    schedulePortraitHydration();
  }

  function eventDedupeKey(title, date, city) {
    const d = date ? new Date(date).toISOString().slice(0, 10) : "";
    return `${d}|${key(city)}|${key(cleanEventTitle(title)).replace(/summitwindow|announced|public|meeting|conference/g, "")}`;
  }

  function sourceEventTokens(title) {
    const t = key(cleanEventTitle(title));
    const families = ["quad", "g7", "g20", "brics", "nato", "bilderberg", "davos", "jackson hole", "shangri la", "raisina", "oecd", "sintra", "fomc", "opec", "ceraweek", "adipec", "fii", "milken", "sun valley", "apec", "unga", "cop", "imf", "world bank"];
    const hit = families.find((f) => t.includes(key(f)));
    if (hit === "quad") return ["quad"];
    if (hit === "imf") return ["imf"];
    if (hit === "world bank") return ["world", "bank"];
    if (hit) return key(hit).split(" ");
    const generic = new Set(["foreign", "minister", "ministers", "ministerial", "travel", "index", "meeting", "summit", "forum", "conference", "dialogue", "public", "agenda", "watch", "new", "delhi", "geneva", "paris", "washington", "annual", "leaders"]);
    return t.split(" ").filter((x) => x.length > 4 && !generic.has(x) && !/^20\d{2}$/.test(x)).slice(0, 2);
  }

  function cleanEventTitle(title) {
    return String(title || "Event").replace(/ announced summit window| announced summit| public summit window/ig, "").replace(/\s+/g, " ").trim();
  }

  function summitGroups() {
    const futureRecords = appearances.filter((a) => isFuture(a) && /summit|g7|g20|nato|conference|forum/i.test([a.title, a.eventType, ...(a.topics || [])].join(" ")));
    const m = new Map();
    for (const a of futureRecords) {
      const k = `${new Date(a.startsAt).toISOString().slice(0, 10)}|${a.location.city}|${a.title}`;
      const g = m.get(k) || { key: k, title: a.title, date: a.startsAt, location: a.location, records: [], people: [], sources: [] };
      g.records.push(a);
      const p = peopleById.get(a.personId);
      if (p && !g.people.some((x) => x.id === p.id)) g.people.push(p);
      (a.sourcePack || []).forEach((src) => g.sources.push(src));
      m.set(k, g);
    }
    return [...m.values()].sort((a, b) => new Date(a.date) - new Date(b.date));
  }


  function focusAgenda(agendaId) {
    const list = uniqueAgendas(eventAgendas);
    const agenda = list.find((a) => String(a.id || key(a.title + a.startsAt)) === String(agendaId))
      || list.find((a) => eventDedupeKey(a.title, a.startsAt, a.location?.city) === agendaId)
      || list.find((a) => key(a.title) === key(agendaId));
    if (!agenda) return;
    stopPlayback();
    selectedPerson = null;
    selectedRoster = null;
    timeline = [];
    currentStep = -1;
    if (els.roster) els.roster.value = "";
    if (els.stepBrief) els.stepBrief.hidden = true;
    if (els.mapFocus) els.mapFocus.hidden = true;
    clearMap();
    const loc = agenda.location || { lat: 20, lng: 0, city: "Public venue", countryCode: "UN", countryName: "International" };
    const title = cleanEventTitle(agenda.title);
    const byRoster = new Map();
    for (const name of agenda.participantNames || []) {
      const p = mappedByName.get(key(name)) || people.find((x) => key(x.canonicalName) === key(name));
      const r = p ? rosterForPerson(p) : roster.find((x) => key(x.name) === key(name) || key(x.name).includes(key(name)) || key(name).includes(key(x.name)));
      if (r) byRoster.set(r.id, { roster: r, person: p || mappedPersonForRoster(r) || null });
    }
    const titleNeedle = key(title).split(" ").filter((x) => x.length > 3).slice(0, 3);
    const participantKeys = new Set((agenda.participantNames || []).map((name) => key(name)).filter(Boolean));
    const nearRecords = appearances.filter((a) => {
      const p = peopleById.get(a.personId);
      const days = Math.abs((new Date(a.startsAt) - new Date(agenda.startsAt || a.startsAt)) / DAY);
      const sameCity = key(a.location?.city) === key(loc.city);
      const hay = key([a.title, a.eventType, a.summary, ...(a.topics || [])].join(" "));
      const titleHit = titleNeedle.some((t) => hay.includes(t));
      const personKey = key(p?.canonicalName || "");
      const personNamed = [...participantKeys].some((k) => k && (personKey === k || personKey.includes(k) || k.includes(personKey)));
      return sameCity && days <= 4 && (personNamed || (!participantKeys.size && titleHit));
    }).slice(0, 60);
    for (const a of nearRecords) {
      const p = peopleById.get(a.personId);
      const r = p && rosterForPerson(p);
      if (p && r) byRoster.set(r.id, { roster: r, person: p });
    }
    const peopleList = [...byRoster.values()];
    els.mapTitle.textContent = title;
