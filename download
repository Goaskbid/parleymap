        const points = deOverlapAnchors(uniqueLocs.slice(0, 60).map((loc) => ({ anchor: loc, trueAnchor: loc, roster: { id: "", name: title, countryFocus: loc.countryCode, countryName: loc.countryName }, person: null })));
