      if (known) {
        setPortraitNode(node, known);
      } else if (title && !portraitTitleRequests.has(key(title))) {
        portraitTitleRequests.add(key(title));
        missing.push({ title, nodeName: node.dataset.personName || title });
      }
    }
    if (!missing.length) return;
    for (let i = 0; i < missing.length; i += 40) {
      const batch = missing.slice(i, i + 40);
      try {
        const params = new URLSearchParams({
          action: "query",
          origin: "*",
          format: "json",
          redirects: "1",
          prop: "pageimages",
          piprop: "thumbnail",
          pithumbsize: "220",
          titles: batch.map((x) => x.title).join("|")
        });
        const res = await fetch(`https://en.wikipedia.org/w/api.php?${params.toString()}`);
        if (!res.ok) continue;
        const json = await res.json();
        const byTitle = new Map();
        batch.forEach((x) => {
          byTitle.set(key(x.title), x);
          byTitle.set(key(String(x.title).replaceAll("_", " ")), x);
          byTitle.set(key(x.nodeName), x);
        });
        (json.query?.normalized || []).forEach((n) => { const x = byTitle.get(key(n.from)); if (x) byTitle.set(key(n.to), x); });
        (json.query?.redirects || []).forEach((n) => { const x = byTitle.get(key(n.from)); if (x) byTitle.set(key(n.to), x); });
        Object.values(json.query?.pages || {}).forEach((page) => {
          const url = cleanPortraitUrl(page?.thumbnail?.source || "");
          const match = byTitle.get(key(page?.title));
          if (!url || !match) return;
          portraitByTitle.set(key(page.title), url);
          portraitByTitle.set(key(match.title), url);
          portraitByTitle.set(key(match.nodeName), url);
          const r = roster.find((x) => key(x.wikiTitle) === key(match.title) || key(x.name) === key(match.nodeName) || key(x.name) === key(page.title));
          if (r && !r.imageUrl) r.imageUrl = url;
          const p = people.find((x) => key(x.canonicalName) === key(match.nodeName) || key(x.wikiTitle) === key(match.title) || key(x.canonicalName) === key(page.title));
          if (p && !p.imageUrl) p.imageUrl = url;
          qsAll(".avatar-photo[data-wiki-title]").forEach((node) => {
            if (key(node.dataset.wikiTitle) === key(match.title) || key(node.dataset.personName) === key(match.nodeName) || key(node.dataset.personName) === key(page.title)) setPortraitNode(node, url);
          });
        });
      } catch (_) {}
    }
  }

