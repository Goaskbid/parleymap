  function uniqueAgendas(items) {
    const seen = new Map();
    for (const item of items || []) {
      const cleanedTitle = key(String(item.title || "").replace(/leaders’?|summit|meeting|conference|forum|watch|announced|public|window|annual|ministerial|council|2027|2026|2025|2024/gi, ""));
      const words = cleanedTitle.split(" ").filter(Boolean);
      const signature = ["g7","g20","nato","brics","apec","cop","wef","davos","bilderberg","jackson","sintra","opec","imf","world","bank","oecd","fii","adipec","ceraweek","shangri","raisina","milken","ambrosetti","sun","valley","wto"].find((w) => words.includes(w)) || words.slice(0, 2).join(" ") || key(item.type || "event");
      const date = item.startsAt ? new Date(item.startsAt).toISOString().slice(0, 10) : "date";
      const city = key(item.location?.city || "");
      const k = `${date}|${city}|${signature}`;
      const old = seen.get(k);
      if (!old) seen.set(k, item);
      else {
        old.participantNames = [...new Set([...(old.participantNames || []), ...(item.participantNames || [])])];
        old.sourcePack = [...(old.sourcePack || []), ...(item.sourcePack || [])];
        old.topics = [...new Set([...(old.topics || []), ...(item.topics || [])])];
        old.sectors = [...new Set([...(old.sectors || []), ...(item.sectors || [])])];
      }
    }
    return [...seen.values()];
  }

