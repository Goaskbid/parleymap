  function networkScoreForPerson(id) {
    const meetingEdges = (encounters || []).filter((e) => (e.participantIds || []).includes(id)).reduce((s,e) => s + Math.max(1, (e.participantIds || []).length - 1), 0);
    const callEdges = (calls || []).filter((c) => c.personId === id || c.counterpartId === id).length * 2;
    const recordEdges = (appearancesByPerson.get(id)?.length || 0);
    const counterpartEdges = appearances.filter((a) => (a.counterpartIds || []).includes(id)).length;
    return meetingEdges + callEdges + recordEdges + counterpartEdges;
  }

