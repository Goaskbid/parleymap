  function curvePoints(a, b, bend) {
    const lat1 = a.lat, lng1 = a.lng, lat2 = b.lat, lng2 = b.lng;
    const midLat = (lat1 + lat2) / 2 + Math.abs(lng2 - lng1) * bend;
    const midLng = (lng1 + lng2) / 2;
    const pts = [];
    for (let i = 0; i <= 32; i++) {
      const t = i / 32, u = 1 - t;
      pts.push([u * u * lat1 + 2 * u * t * midLat + t * t * lat2, u * u * lng1 + 2 * u * t * midLng + t * t * lng2]);
    }
    return pts;
  }

  function distanceKm(a, b) {
    if (!a || !b) return 99999;
    const R = 6371;
    const dLat = (b.lat - a.lat) * Math.PI / 180;
    const dLng = (b.lng - a.lng) * Math.PI / 180;
    const lat1 = a.lat * Math.PI / 180;
    const lat2 = b.lat * Math.PI / 180;
    const h = Math.sin(dLat / 2) ** 2 + Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
    return 2 * R * Math.asin(Math.sqrt(h));
  }

  function project(lat, lng) { return [(lng + 180) / 360 * 100, (90 - lat) / 180 * 100]; }
  function overlaps(a, b) { return !(a.x + a.w < b.x || b.x + b.w < a.x || a.y + a.h < b.y || b.y + b.h < a.y); }
  function groupBy(arr, fn) { const m = new Map(); arr.forEach((x) => { const k = fn(x); if (!m.has(k)) m.set(k, []); m.get(k).push(x); }); return m; }
  function unique(pairs) { const m = new Map(); pairs.forEach(([a, b]) => { if (a && !m.has(a)) m.set(a, b); }); return [...m.entries()]; }
  function key(v) { return String(v || "").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]+/g, " ").trim(); }
  function wikiKey(v) { return String(v || "").replace(/_/g, " ").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]+/g, " ").trim(); }
  function esc(v) { return String(v ?? "").replace(/[&<>'"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "'": "&#39;", '"': "&quot;" }[c])); }
  function escForAttr(v) { return String(v ?? "").replace(/[\\'"\n\r]/g, (c) => ({ "\\": "\\\\", "'": "\\'", '"': "&quot;", "\n": "", "\r": "" }[c])); }
  function qs(sel, root = document) { return root.querySelector(sel); }
  function qsAll(sel, root = document) { return [...root.querySelectorAll(sel)]; }
  function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }
