      { n: encounters.length, label: "meetings", title: "Encounter clusters", detail: `${encounters.length} documented co-presence or meeting clusters.`, body: topNames(encounters.slice(0, 10).map((e) => e.title || e.id)) },
      { n: calls.length, label: "call readouts", title: "Public call readouts", detail: `${calls.length} official or public phone-call cards.`, body: topNames(calls.slice(0, 10).map((c) => c.title || "public call")) },
      { n: cities, label: "cities", title: "Strategic cities", detail: `${cities} mapped city clusters.`, body: topNames([...citiesMap.values()].sort((a, b) => b.value - a.value).slice(0, 8).map((c) => `${c.city}: ${c.value} records, ${c.people.size} people`)) },
      { n: "24m", label: "crawler window", title: "Crawler window", detail: "Nightly job looks back 24 months and watches future public agendas.", body: `Source types in current cards: ${topPairs(sourceKinds, 6)}.` }
