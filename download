  function deOverlapAnchors(items) {
    const placed = [];
    const minGap = state.openingPreset === "ALL" || items.length > 80 ? 3.4 : items.length > 18 ? 5.1 : 6.6;
    return items.map((item, idx) => {
      const source = { ...(item.trueAnchor || item.anchor) };
      const candidates = [{ lat: source.lat, lng: source.lng, shiftedForDisplay: false }];
      const rings = state.openingPreset === "ALL" ? 6 : 9;
      for (let ring = 1; ring <= rings; ring++) {
        const steps = 8 + ring * 4;
        const spread = minGap * (0.72 + ring * 0.48);
        for (let j = 0; j < steps; j++) {
          const angle = ((j / steps) * Math.PI * 2) + idx * 0.87 + ring * 0.31;
          const lat = clamp(source.lat + Math.sin(angle) * spread, -68, 75);
          const lng = wrapLng(source.lng + Math.cos(angle) * spread / Math.max(0.35, Math.cos((source.lat || 0) * Math.PI / 180)));
          candidates.push({ lat, lng, shiftedForDisplay: true });
        }
      }
      let best = candidates[0];
      let bestScore = Infinity;
      for (const cand of candidates) {
        let crowdPenalty = 0;
        for (const other of placed) {
          const d = displayDistance(cand, other.anchor);
          if (d < minGap) crowdPenalty += Math.pow((minGap - d) * 12, 2);
          const segmentGap = segmentDistance(source, cand, other.source, other.anchor);
          if (cand.shiftedForDisplay && other.shiftedForDisplay && segmentGap < minGap * .45) crowdPenalty += Math.pow((minGap * .45 - segmentGap) * 6, 2);
        }
        const move = displayDistance(source, cand);
        const score = crowdPenalty + move * (cand.shiftedForDisplay ? .85 : .08);
        if (score < bestScore) { best = cand; bestScore = score; }
        if (crowdPenalty === 0 && cand.shiftedForDisplay) break;
      }
      const shifted = best.shiftedForDisplay || displayDistance(source, best) > .35;
      const anchor = { ...source, lat: best.lat, lng: best.lng, shiftedForDisplay: shifted };
      const out = { ...item, trueAnchor: source, originalAnchor: source, anchor, shiftedForDisplay: shifted, leaderBend: shifted ? ((idx % 2 ? .055 : -.055) + (idx % 5) * .012) : 0 };
      placed.push({ source, anchor });
      return out;
    });
  }

  function displayDistance(a, b) {
    if (!a || !b) return 999;
    const lat = ((a.lat || 0) + (b.lat || 0)) / 2 * Math.PI / 180;
    let dx = Math.abs((a.lng || 0) - (b.lng || 0));
    dx = Math.min(dx, 360 - dx) * Math.max(.35, Math.cos(lat));
    const dy = (a.lat || 0) - (b.lat || 0);
    return Math.sqrt(dx * dx + dy * dy * 1.55);
  }

  function segmentDistance(a, b, c, d) {
    if (!a || !b || !c || !d) return 999;
    const ax = a.lng || 0, ay = a.lat || 0, bx = b.lng || 0, by = b.lat || 0;
    const cx = c.lng || 0, cy = c.lat || 0, dx = d.lng || 0, dy = d.lat || 0;
    return Math.min(pointToSegmentDistance(ax, ay, cx, cy, dx, dy), pointToSegmentDistance(bx, by, cx, cy, dx, dy), pointToSegmentDistance(cx, cy, ax, ay, bx, by), pointToSegmentDistance(dx, dy, ax, ay, bx, by));
  }

  function pointToSegmentDistance(px, py, ax, ay, bx, by) {
    const vx = bx - ax, vy = by - ay;
    const wx = px - ax, wy = py - ay;
    const c1 = vx * wx + vy * wy;
    if (c1 <= 0) return Math.hypot(px - ax, py - ay);
    const c2 = vx * vx + vy * vy;
    if (c2 <= c1) return Math.hypot(px - bx, py - by);
    const t = c1 / c2;
    return Math.hypot(px - (ax + t * vx), py - (ay + t * vy));
  }

  function wrapLng(lng) {
    let x = Number(lng || 0);
    while (x > 180) x -= 360;
    while (x < -180) x += 360;
    return x;
  }


