  function topicsForRecord(x) {
    const cacheKey = x?.id || `${x?.title || "record"}|${x?.startsAt || x?.date || ""}|${x?.location?.city || ""}`;
    if (recordTopicCache.has(cacheKey)) return recordTopicCache.get(cacheKey);
    const hay = recordHay(x) + " " + agendaHay(x);
    const direct = (x.topics || []).map((t) => normalizeTopicName(t)).filter(isUsefulTopicName);
    const directSet = new Set(direct.map((t) => key(t)));
    const inferred = [];
    for (const t of topicFamilies()) {
      if (directSet.has(key(t.name)) || t.rx.test(hay)) inferred.push(t.name);
    }
    const out = [...new Set([...direct, ...inferred].map(normalizeTopicName).filter(isUsefulTopicName))];
    recordTopicCache.set(cacheKey, out);
