  function networkRowsFromSources(def) {
    const apps = appearances.filter((a)=>def.rx.test(recordHay(a)));
    const agendas = uniqueAgendas(eventAgendas).filter((a)=>def.rx.test(agendaHay(a)));
    const byPerson = new Map();
    apps.forEach((rec)=>{
      const p=peopleById.get(rec.personId); if(!p || !rec.location) return;
      const row=byPerson.get(p.id)||{person:p, records:[], citiesSet:new Set(), latest:rec, fromAgenda:false};
      row.records.push(rec); row.citiesSet.add(rec.location.city || rec.location.countryName || 'public venue');
      if(new Date(rec.startsAt)>new Date(row.latest.startsAt)) row.latest=rec;
      byPerson.set(p.id,row);
    });
    agendas.forEach((ag)=>{
      peopleFromNames(ag.participantNames || []).forEach((p)=>{
        const row=byPerson.get(p.id)||{person:p, records:[], citiesSet:new Set(), latest:{...ag, personId:p.id}, fromAgenda:true};
        row.records.push({...ag, personId:p.id, eventType:ag.type || 'Agenda watch'}); row.citiesSet.add(ag.location?.city || 'public venue');
        if(!row.latest || new Date(ag.startsAt)>new Date(row.latest.startsAt)) row.latest={...ag, personId:p.id};
        byPerson.set(p.id,row);
      });
    });
    if (!byPerson.size) {
      roster.filter((r)=>def.rx.test([r.name,r.roleTitle,r.bucket,r.sector,r.organization,r.countryName].join(' '))).slice(0, 16).forEach((r)=>{
        const p = mappedPersonForRoster(r); if (!p) return;
        const loc = homeBaseFor(p, r);
        byPerson.set(p.id, { person:p, records:[], citiesSet:new Set([loc.city]), latest:{ id:`watch-${p.id}`, title:`${def.name} watch`, startsAt:now.toISOString(), location:loc, eventType:'Watch layer' }, fromAgenda:true });
      });
    }
    const personRows = [...byPerson.values()].map((row)=>({ ...row, cities:[...row.citiesSet], score:row.records.length*4 + row.citiesSet.size })).sort((a,b)=>b.score-a.score);
    const cityMap = new Map();
    [...apps, ...agendas].forEach((rec)=>{
      const loc=rec.location; if(!loc || !Number.isFinite(+loc.lat) || !Number.isFinite(+loc.lng)) return;
      const k=`${loc.city}|${loc.countryCode}`;
      const c=cityMap.get(k)||{city:loc.city,countryCode:loc.countryCode,countryName:loc.countryName,lat:loc.lat,lng:loc.lng,count:0,people:new Set(),records:[]};
      c.count += 1; c.records.push(rec); if(rec.personId) c.people.add(rec.personId); (rec.participantNames||[]).forEach((name)=>{ const p=peopleFromNames([name])[0]; if(p) c.people.add(p.id); }); cityMap.set(k,c);
    });
    personRows.forEach((r)=>{ const loc=r.latest?.location; if(!loc) return; const k=`${loc.city}|${loc.countryCode}`; const c=cityMap.get(k)||{city:loc.city,countryCode:loc.countryCode,countryName:loc.countryName,lat:loc.lat,lng:loc.lng,count:0,people:new Set(),records:[]}; c.count += Math.max(1,r.records.length); c.people.add(r.person.id); cityMap.set(k,c); });
    return { apps, agendas, personRows, cityRows:[...cityMap.values()].sort((a,b)=>b.count-a.count) };
  }

