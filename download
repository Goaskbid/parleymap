  function coreEventFamiliesV49() {
    const wanted = ["Davos", "Bilderberg", "Munich", "FII", "G7", "G20", "BRICS", "APEC", "NATO", "UNGA", "COP", "Jackson Hole", "ECB Sintra", "BIS", "IMF / World Bank", "FOMC", "Shangri-La", "Raisina"];
