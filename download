  function renderEventOverlapMatrix() {
    if (!els.eventOverlapMatrix) return;
    const families = eventFamilies().filter((f)=>!/^Federal Reserve FOMC/i.test(f.name)).slice(0, 18);
    const rows = families.map((f)=>({ family:f, hit:familyHits(f), peopleSet:new Set(familyHits(f).people.map((p)=>p.id)) }));
    const pairData = [];
    for (let i=0;i<rows.length;i++) for (let j=i+1;j<rows.length;j++) {
      const shared = [...rows[i].peopleSet].filter((id)=>rows[j].peopleSet.has(id));
      const denom = Math.max(1, Math.min(rows[i].peopleSet.size || 1, rows[j].peopleSet.size || 1));
      const pct = Math.round(shared.length / denom * 100);
      if (pct > 0) pairData.push({a:rows[i], b:rows[j], shared, pct});
    }
    const clusters = pairData.sort((a,b)=>b.pct-a.pct || b.shared.length-a.shared.length).slice(0, 6).map((p)=>
      `<button type="button" class="matrix-cluster-v49" data-matrix-event="${esc(p.a.family.name)}" data-hover-title="${esc(p.a.family.name + ' / ' + p.b.family.name)}" data-hover-detail="${esc(p.pct + '% overlap')}" data-hover-body="${esc(p.shared.length + ' named people are visible in both event systems.')}" aria-label="Open ${esc(p.a.family.name)} layer"><span>${esc(p.a.family.name)}</span><b>↔</b><span>${esc(p.b.family.name)}</span><strong>${p.pct}</strong></button>`).join('');
    const n = rows.length;
    const headers = rows.map((r)=>`<button type="button" class="matrix-axis x" data-matrix-event="${esc(r.family.name)}" title="${esc(r.family.name)}">${esc(shortOrg(r.family.name))}</button>`).join('');
    const body = rows.map((row,i)=>{
      const cells = rows.map((col,j)=>{
        const shared = i===j ? row.peopleSet.size : [...row.peopleSet].filter((id)=>col.peopleSet.has(id)).length;
        const pct = i===j ? 100 : Math.round(shared / Math.max(1, Math.min(row.peopleSet.size || 1, col.peopleSet.size || 1)) * 100);
        const names = [...row.peopleSet].filter((id)=>col.peopleSet.has(id)).slice(0,6).map((id)=>peopleById.get(id)?.canonicalName).filter(Boolean).join(', ');
        return `<button type="button" class="matrix-cell-v49 ${i===j?'self':''}" style="--heat:${pct}" data-matrix-event="${esc(row.family.name)}" data-hover-title="${esc(row.family.name + ' / ' + col.family.name)}" data-hover-detail="${esc(pct + '% · ' + shared + ' shared people')}" data-hover-body="${esc(names || 'Shared names appear as the crawler promotes source-backed attendance.')}" aria-label="${esc(row.family.name)} to ${esc(col.family.name)} overlap ${pct} percent"><strong>${pct}</strong><small>${shared}</small></button>`;
      }).join('');
      return `<div class="matrix-row-v49"><button type="button" class="matrix-axis y" data-matrix-event="${esc(row.family.name)}" title="${esc(row.family.name)}">${esc(row.family.name)}</button>${cells}</div>`;
    }).join('');
    els.eventOverlapMatrix.innerHTML = `<div class="matrix-intro-v49"><strong>Shared-attendee overlap</strong><span>Rows and columns are event systems. Brighter cells mean the same named people recur in both places. Click a row or a cell to open that layer on the map.</span></div><div class="matrix-clusters-v49">${clusters}</div><div class="matrix-v49" style="--n:${n}"><div class="matrix-head-v49"><span class="matrix-corner-v49">Event</span>${headers}</div>${body}</div>`;
    qsAll('[data-matrix-event]', els.eventOverlapMatrix).forEach((b)=>b.addEventListener('click',()=>focusNetwork(b.dataset.matrixEvent)));
  }

