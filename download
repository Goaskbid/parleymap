  function recordMatchesTerm(a, term) {
    const hay = key([a.title, a.eventType, a.summary, ...(a.topics || [])].join(" "));
    if (!term) return false;
    if (hay.includes(term)) return true;
    const words = term.split(/\s+/).filter((w) => w.length > 3);
    return words.length ? words.some((w) => hay.includes(w)) : false;
  }

  function focusEventCategory(category) {
    const catalog = (eventUniverse.length ? eventUniverse : influenceEventCatalog).map((e) => ({ ...e, eventName: e.event || e.name || e.title || "Influence event", fields: e.attendeeGraphFields || e.trackerFields || ["event", "person", "organisation", "role", "year", "speaker/attendee", "source URL"] }));
    const defs = catalog.filter((e) => (e.category || "Event graph") === category);
    if (!defs.length) return;
    const terms = defs.map((e) => key(e.eventName)).filter(Boolean);
    const matches = appearances.filter((a) => terms.some((term) => recordMatchesTerm(a, term)));
    if (matches.length) focusNetwork(category);
    els.profile.innerHTML = `<div class="summit-profile"><h3>${esc(category)}</h3><p>${esc(defs.length + " tracked event types")}</p><div class="bio-lines">${defs.map((e) => `<div><strong>${esc(e.eventName)}:</strong> ${esc(e.why || "Track public attendees, speakers and official source links.")}<br><span>${esc((e.fields || []).join(", "))}</span></div>`).join("")}</div></div>`;
  }


  function renderInfluenceEventGraph() {
    if (!els.rankEventGraph) return;
    const grouped = new Map();
    for (const raw of influenceEventCatalog || []) {
      const category = raw.category || raw.group || "Influence events";
      const events = Array.isArray(raw.events) ? raw.events : [raw.name || raw.title || category];
      const cur = grouped.get(category) || { category, events: [], why: raw.why || "Track repeated attendance and source-backed public participation.", scoreBase: 0 };
      cur.events.push(...events);
      cur.scoreBase += Number(raw.priority === "must-follow" ? 4 : raw.priority === "high" ? 2 : 1);
      if (raw.why && cur.why.length < raw.why.length) cur.why = raw.why;
      grouped.set(category, cur);
    }
    const rows = [...grouped.values()].map((group) => {
      const rx = new RegExp([...new Set(group.events)].map(escapeRegex).join("|"), "i");
      const agendaHits = eventAgendas.filter((a) => rx.test([a.title, a.type, a.whyItMatters, ...(a.topics || [])].join(" ")));
      const recordHits = appearances.filter((a) => rx.test([a.title, a.eventType, a.summary, ...(a.topics || [])].join(" ")));
      return { ...group, events: [...new Set(group.events)], agendaHits, recordHits, score: agendaHits.length * 3 + recordHits.length + group.scoreBase };
    }).sort((a, b) => b.score - a.score);
    els.rankEventGraph.innerHTML = rows.map((row) => {
      const body = `${row.why} Track: event, person, organisation, role, year, speaker/attendee status and source URL.`;
      return `<button type="button" class="agenda-row network-row" data-event-group="${esc(row.category)}" data-hover-title="${esc(row.category)}" data-hover-detail="${esc(row.events.join(' · '))}" data-hover-body="${esc(body)}"><span class="agenda-date">${esc(String(row.score))}</span><strong>${esc(row.category)}</strong><em>${esc(row.events.slice(0, 4).join(' · '))}</em></button>`;
