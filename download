  function hydrateHeader() {
    els.headerData.textContent = shortDateTime(data.meta?.lastDataUpdate || data.meta?.generatedAt);
    els.headerReview.textContent = data.meta?.lastTop200Review || data.meta?.lastTop100Review || "review pending";
    els.headerImport.textContent = data.meta?.importStatus || "nightly public-source queue";
  }

  function hydrateControls() {
    els.roster.innerHTML = `<option value="">Choose a global figure…</option>` + roster.map((p) => {
      const trail = mappedPersonForRoster(p) ? "trail" : "profile";
      const flag = flagEmoji(p.countryFocus);
      return `<option value="${esc(p.id)}">${esc(flag)} ${esc(p.name)} — ${esc(p.countryName || "Global")} — ${esc(p.bucket || p.roleTitle)} — ${esc(trail)}</option>`;
    }).join("");

    els.category.innerHTML = `<option value="ALL">All roles</option>` + categories.map((c) => `<option value="${esc(c.id)}">${esc(c.label || c.id)}</option>`).join("");
    const countries = unique([...appearances.map((a) => [a.location.countryCode, a.location.countryName]), ...roster.map((p) => [p.countryFocus, p.countryName])].filter((x) => x[0]));
    els.country.innerHTML = `<option value="ALL">All countries</option>` + countries.sort((a, b) => String(a[1]).localeCompare(String(b[1]))).map(([code, name]) => `<option value="${esc(code)}">${esc(flagEmoji(code))} ${esc(name || code)}</option>`).join("");
    const sectors = [...new Set([...people.map((p) => p.sector), ...roster.map((p) => p.sector)].filter(Boolean))].sort();
    els.sector.innerHTML = `<option value="ALL">All sectors</option>` + sectors.map((s) => `<option value="${esc(s)}">${esc(s)}</option>`).join("");
  }

  function bindControls() {
    qs("#brand-reset")?.addEventListener("click", resetOpeningMap);
    qs("#top20-reset")?.addEventListener("click", resetOpeningMap);
    qs("#start-roadmovie")?.addEventListener("click", startDefaultRoadmovie);
    els.openingPreset?.addEventListener("change", () => {
      state.openingPreset = els.openingPreset.value || "TOP10";
      renderTop20List();
      renderOpeningMap();
      renderRankings();
      updateRoadmovieButton();
    });
    els.drawerToggle?.addEventListener("click", () => {
      const open = els.drawer.hidden;
      els.drawer.hidden = !open;
      els.drawerToggle.setAttribute("aria-expanded", String(open));
    });
    els.roster?.addEventListener("change", () => selectRoster(els.roster.value));
    els.quickSearch?.addEventListener("input", () => {
      state.query = els.quickSearch.value || "";
      if (els.search) els.search.value = state.query;
      renderQuickResults(state.query);
      renderTop20List();
      renderOpeningMap();
      renderRankings();
      updateRoadmovieButton();
    });
    els.quickSearch?.addEventListener("focus", () => renderQuickResults(els.quickSearch.value));
    document.addEventListener("click", (e) => {
      if (els.quickResults && !e.target.closest(".finder-wrap")) els.quickResults.hidden = true;
    });

    for (const [el, keyName] of [[els.search, "query"], [els.time, "time"], [els.category, "category"], [els.country, "country"], [els.sector, "sector"], [els.sort, "sort"]]) {
      el?.addEventListener("input", () => {
        state[keyName] = el.value || (keyName === "query" ? "" : "ALL");
        renderTop20List();
        renderOpeningMap();
        renderRankings();
        updateRoadmovieButton();
      });
    }
    for (const [el, keyName] of [[els.heat, "showHeat"], [els.paths, "showPaths"], [els.future, "showFuture"], [els.labels, "showLabels"], [els.calls, "showCalls"]]) {
      el?.addEventListener("change", () => {
        state[keyName] = !!el.checked;
        renderCurrentMap();
      });
    }
    qsAll("[data-action]").forEach((button) => button.addEventListener("click", () => handleTimelineAction(button.dataset.action)));
