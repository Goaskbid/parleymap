      { n: roster.length, label: "top-200 profiles", title: "Top-200 roster", detail: `${roster.length} profiles in the current roster.`, body: topNames(roster.slice(0, 12).map((r) => r.name)) },
      { n: mappedPeople, label: "mapped pilots", title: "Mapped profiles", detail: `${mappedPeople} people have visible public records in this static build.`, body: topNames(people.slice(0, 12).map((p) => p.canonicalName)) },
