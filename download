      const bounds = [];
      for (const point of points) {
        const actual = point.trueAnchor || point.anchor;
        const display = point.anchor;
        drawHeat(actual, 1.1, countryColor(actual.countryCode));
        const marker = L.marker([display.lat, display.lng], { icon: stopDivIcon({ kind: "event", date: item.name, record: { location: actual, title: item.name } }, point.index || 0, "network"), riseOnHover: true, keyboard: true });
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.name, detail: `${actual.city}, ${actual.countryName}`, body: item.why || item.category }));
        marker.on("mousemove", (e) => moveHover(e.originalEvent));
        marker.on("mouseout", hideHover);
        marker.addTo(layers.markers);
        bounds.push([display.lat, display.lng]);
