    return `<svg class="avatar-svg avatar-fallback" viewBox="0 0 100 100" aria-hidden="true"><defs><linearGradient id="af${h}" x1="0" x2="1" y1="0" y2="1"><stop offset="0" stop-color="#0b1422"/><stop offset="1" stop-color="${esc(c1)}"/></linearGradient></defs><rect width="100" height="100" fill="url(#af${h})"/><circle cx="50" cy="42" r="24" fill="none" stroke="rgba(255,255,255,.42)" stroke-width="3"/><path d="M22 78c8-17 18-25 28-25s20 8 28 25" fill="rgba(255,255,255,.12)" stroke="rgba(255,255,255,.35)" stroke-width="3"/><path d="M15 18h70M15 82h70" stroke="${esc(c2)}" stroke-width="3" opacity=".78"/><text x="50" y="48" text-anchor="middle" fill="#fff" font-family="Arial Narrow, Arial" font-size="25" font-weight="900" letter-spacing="1">${esc(initials)}</text></svg>`;
  }

  function normalizeRoster(p) {
    const name = p.name || p.canonicalName || "Global figure";
    const countryName = p.countryName || p.country || p.region || "Global";
    const countryFocus = p.countryFocus || p.countryCode || (String(p.country || "").length === 2 ? p.country : countryCode(countryName));
    return { ...p, name, canonicalName: name, countryName, countryFocus, roleTitle: p.roleTitle || p.bucket || "Public figure", sector: p.sector || p.industry || "Public life" };
  }
  function countryCode(name) {
    const map = { "United States":"US", "China":"CN", "Russia":"RU", "India":"IN", "France":"FR", "Germany":"DE", "United Kingdom":"GB", "Italy":"IT", "Saudi Arabia":"SA", "United Arab Emirates":"AE", "Israel":"IL", "Iran":"IR", "European Union":"EU", "United Nations":"UN", "NATO":"NATO", "Canada":"CA", "Brazil":"BR", "Turkey":"TR", "Japan":"JP", "South Korea":"KR", "Indonesia":"ID", "Mexico":"MX", "South Africa":"ZA", "Australia":"AU", "Spain":"ES", "Netherlands":"NL", "Belgium":"BE", "Switzerland":"CH", "Sweden":"SE", "Norway":"NO", "Denmark":"DK", "Finland":"FI", "Poland":"PL", "Ukraine":"UA", "Qatar":"QA", "Singapore":"SG", "Taiwan":"TW", "Portugal":"PT", "Kuwait":"KW", "OECD":"OC", "BIS":"BI", "IMF":"IM", "World Bank":"WB", "WHO":"WH", "WTO":"WT", "IAEA":"IA", "IOC":"IO", "FIFA":"FIFA", "OPEC":"OP", "Gavi":"GV", "World Economic Forum":"WEF", "International Energy Agency":"IEA", "Sri Lanka":"LK", "IEA":"IEA" };
    return map[name] || "UN";
  }
  /* v4.8 finishing pass: UK-English labels, useful network fallbacks, cleaner source labels, richer topic/timeline/presentation panels. */
  function sourceLabel(s) {
    const raw = String(s?.label || s?.type || "source").trim();
    const url = String(s?.url || "").trim();
    if (!url || !raw || /geocode audit|map audit|placeholder|source watch pending/i.test(raw)) return "";
    const host = (() => { try { return new URL(url).hostname.replace(/^www\./, ""); } catch { return ""; } })();
    const low = `${raw} ${host}`.toLowerCase();
    const readableHost = host.split(".").slice(0, -1).join(".").replace(/[-_]/g, " ").replace(/\b\w/g, c => c.toUpperCase());
    if (/investor|ir\.|annual-report|shareholder|sec\.gov|10-k|20-f/.test(low)) return oneLine(`${readableHost || "Company"} investor relations`, 46);
    if (/press|news|media|remarks|release|statement|readout|speech/.test(low)) return oneLine(`${readableHost || raw} news`, 46);
    if (/event|agenda|programme|program|participants|summit|conference|meeting/.test(low)) return oneLine(`${readableHost || raw} event page`, 46);
    if (/whitehouse|state\.gov|gov\.uk|kremlin|mfa|elysee|pmindia|presidency|commission|consilium|nato|un\.org|oecd|bis|ecb|federalreserve|bankofengland|boj|bankofcanada/.test(low)) return oneLine(`${readableHost || "Institutional"} record`, 46);
    if (/reuters|apnews|bbc|ft|wsj|bloomberg|nytimes|guardian|economist|politico|axios|cnn|aljazeera|dw|france24/.test(low)) return oneLine(`${readableHost || raw} article`, 46);
    if (/official/i.test(raw)) return oneLine(`${readableHost || "Primary source"} page`, 46);
    return oneLine(raw, 46);
  }

  function normalizeTopicName(name) {
    const raw = oneLine(name || "", 80).trim();
    if (!raw) return "";
    const k = key(raw);
    const map = [
      [/\b(ai|artificial intelligence|openai|machine learning|llm|digital transformation|cloud|compute|gpu|data centre|data center)\b/i, "AI"],
      [/\b(defence|defense|military|security|nato|munich security|shangri\-la|weapons|deterrence|airshow|aerospace)\b/i, "Defence"],
      [/\b(inflation|rates|monetary|central bank|fed|ecb|fomc|jackson hole|liquidity|sintra)\b/i, "Monetary policy"],
      [/\b(energy|oil|gas|opec|ceraweek|adipec|lng|power grid|commodities)\b/i, "Energy"],
      [/\b(china|beijing|xi|apec|boao|indo\-pacific)\b/i, "China"],
      [/\b(semiconductor|semiconductors|chips|nvidia|tsmc|computex|supply chain)\b/i, "Semiconductors"],
      [/\b(climate|cop\d*|carbon|transition|green finance|unfccc)\b/i, "Climate"],
      [/\b(trade|wto|tariff|supply chain|industrial policy|apec|critical minerals)\b/i, "Trade"],
      [/\b(ukraine|zelensky|peace talks|ceasefire|war diplomacy)\b/i, "Ukraine"],
      [/\b(riyadh|abu dhabi|doha|israel|iran|saudi|gulf|middle east)\b/i, "Middle East"],
      [/\b(debt|imf|world bank|development finance|emerging markets|financing)\b/i, "Debt"],
      [/\b(who|health|gavi|pandemic|vaccine|public health)\b/i, "Health"],
      [/\b(cyber|cybersecurity|security technology|disinformation)\b/i, "Cyber"],
      [/\b(space|satellite|spacex|defence space)\b/i, "Space"],
      [/\b(crypto|digital assets|stablecoin|payments|cbdc)\b/i, "Payments"],
      [/\b(sovereign wealth|fii|public investment fund|pif|gic|adia|capital allocation|private equity|asset manager)\b/i, "Capital"],
      [/\b(food|agriculture|grain|fertilizer|fertiliser)\b/i, "Food security"],
      [/\b(diplomacy|diplomatic|foreign minister|multilateral|global governance|unga|un general assembly)\b/i, "Diplomacy"]
    ];
    for (const [rx, value] of map) if (rx.test(raw)) return value;
    if (/^(us|u\.s\.|usa|united states|policy|public|meeting|summit|event|appearance|government|minister|president|prime minister|foreign ministry|foreign minister|foreign ministers|source|official|agenda|watch|cloud|geopolitics|global governance)$/i.test(raw)) return "";
    if (raw.length < 3 || raw.length > 30) return "";
    if (/\d/.test(raw) && !/cop\d/i.test(raw)) return "";
    const words = raw.split(/\s+/);
    if (words.length > 3) return "";
    return titleCase(raw);
  }

  function isUsefulTopicName(name) {
    const n = key(name);
    if (!n || n.length < 2) return false;
    const reject = new Set(["foreign minister", "foreign ministers", "un", "eu", "united states", "policy", "government", "public", "event", "events", "meeting", "meetings", "summit", "summits", "conference", "forum", "forums", "source", "official", "visit", "visits", "travel", "agenda", "watch", "leader", "leaders", "frequent traveller", "frequent traveler", "cloud", "geopolitics", "development", "global governance"]);
    if (reject.has(n)) return false;
    if (/^(g7|g20|brics|apec|nato|opec|bis|imf|wef|fii|wto|oecd)$/.test(n)) return false;
    if (/^\d{4}$/.test(n)) return false;
    return true;
  }

