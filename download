    const matches = appearances.filter((a) => rx.test([a.title, a.eventType, a.summary, ...(a.topics || [])].join(" ")));
    if (!matches.length) return;
    stopPlayback(); selectedPerson = null; selectedRoster = null; timeline = []; currentStep = -1; clearMap();
    els.mapTitle.textContent = name;
    els.mapStatus.textContent = `${matches.length} public records in this network layer. Click a face to open the person.`;
    const locs = deOverlapAnchors(matches.slice(-80).map((a) => ({ person: peopleById.get(a.personId), roster: rosterForPerson(peopleById.get(a.personId)), anchor: a.location })).filter((x) => x.person));
    if (!fallbackMode && map) {
      const bounds = [];
      drawDisplayLeaderLines(locs);
      locs.forEach((item) => {
        const actual = item.trueAnchor || item.anchor;
        drawHeat(actual, 1.05, countryColor(actual.countryCode));
        const display = item.anchor;
        const marker = L.marker([display.lat, display.lng], { icon: personDivIcon(item.roster || item.person, item.person, { label: shortName(item.person.canonicalName) }), riseOnHover: true, keyboard: true });
        marker.on("click", () => selectRoster((item.roster || rosterForPerson(item.person))?.id));
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.person.canonicalName, detail: `${actual.city}`, body: `${name} record layer.` }));
        marker.on("mousemove", (e) => moveHover(e.originalEvent));
        marker.on("mouseout", hideHover);
        marker.addTo(layers.markers); bounds.push([display.lat, display.lng]);
      });
      if (bounds.length) map.fitBounds(bounds, { padding: [64,64], maxZoom: 5, animate: true });
    }
    els.profile.innerHTML = `<h3>${esc(name)}</h3><p>${matches.length} public records in this source-backed layer.</p><div class="bio-lines">${matches.slice(-12).reverse().map((a) => `<div><strong>${esc(compactDate(a.startsAt))} · ${flagHtml(a.location.countryCode, a.location.countryName)} ${esc(a.location.city)}:</strong> ${esc(oneLine(a.title, 120))}</div>`).join("")}</div>`;
  }

  function agendaPeople(agenda) {
