  }



  function dedupeAppearances(items) {
    const byKey = new Map();
    const badMapAudit = /map audit|geocode audit|placeholder|source watch pending/i;
    const scoreRecord = (a) => {
      let score = 0;
      if (a.location?.precision === "city") score += 2;
      if ((a.sourcePack || []).some((src) => /official|host|primary/i.test([src.type, src.reliability, src.label].join(" ")))) score += 6;
      if ((a.sourcePack || []).some((src) => src.url && !badMapAudit.test(src.label || ""))) score += 3;
      if (/Geneva public-source city/i.test(a.location?.label || "")) score -= 8;
      if (/official|state|ministry|host|calendar|press|visit/i.test([a.title, a.summary, a.eventType].join(" "))) score += 2;
      return score;
    };
    const signature = (a) => {
      const day = a.startsAt ? new Date(a.startsAt).toISOString().slice(0, 10) : "date";
      const person = a.personId || "person";
      const title = key(cleanEventTitle(a.title || a.eventType || "record").replace(/\b(public|official|visit|visits|meeting|record|index|window|watch|announced|to|in|the|of|and|with)\b/gi, " ")).split(" ").filter(Boolean).slice(0, 3).join(" ");
      const city = key(a.location?.city || "");
      const country = String(a.location?.countryCode || "").toUpperCase();
      const knownTrip = title || key((a.topics || []).join(" ")).split(" ").slice(0, 3).join(" ");
      if (person === "s-jaishankar" && day === "2026-05-27" && /cyprus|nicosia/i.test([a.title, a.summary, a.location?.city, a.location?.countryName].join(" "))) return `${person}|${day}|cyprus-visit`;
      return `${person}|${day}|${knownTrip}|${country}|${city}`;
    };
    for (const raw of items || []) {
      const a = { ...raw, sourcePack: (raw.sourcePack || []).filter((src) => src && src.url && src.label && !badMapAudit.test(src.label)) };
      const sig = signature(a);
      const existing = byKey.get(sig);
      if (!existing) { byKey.set(sig, a); continue; }
      const keep = scoreRecord(a) > scoreRecord(existing) ? a : existing;
      const other = keep === a ? existing : a;
      keep.sourcePack = mergeSources([...(keep.sourcePack || []), ...(other.sourcePack || [])]);
      keep.topics = uniqueCleanTopics([...(keep.topics || []), ...(other.topics || [])]);
      keep.counterpartIds = [...new Set([...(keep.counterpartIds || []), ...(other.counterpartIds || [])])];
      keep.summary = keep.summary || other.summary;
      byKey.set(sig, keep);
    }
    return [...byKey.values()].sort((a, b) => new Date(a.startsAt) - new Date(b.startsAt));
  }

  function dedupeAgendaItems(items) {
    const seen = new Map();
    for (const raw of items || []) {
      const a = { ...raw, topics: uniqueCleanTopics(raw.topics || []), sourcePack: mergeSources(raw.sourcePack || []) };
      const day = a.startsAt ? new Date(a.startsAt).toISOString().slice(0, 10) : "date";
      const sig = key(`${day}|${a.location?.city || ""}|${cleanEventTitle(a.title || a.name || a.type || "event")}`.replace(/\b(announced|watch|window|public|summit|meeting|conference|forum|annual|2024|2025|2026|2027)\b/gi, " ")).slice(0, 80);
      const old = seen.get(sig);
      if (!old) { seen.set(sig, a); continue; }
      old.participantNames = [...new Set([...(old.participantNames || []), ...(a.participantNames || [])])];
      old.sourcePack = mergeSources([...(old.sourcePack || []), ...(a.sourcePack || [])]);
      old.topics = uniqueCleanTopics([...(old.topics || []), ...(a.topics || [])]);
      old.whyItMatters = longerUsefulText(old.whyItMatters, a.whyItMatters);
    }
    return [...seen.values()];
  }

  function mergeSources(sources = []) {
    const out = new Map();
    for (const src of sources || []) {
      if (!src || !src.url || !src.label || /map audit|geocode audit|placeholder/i.test(src.label)) continue;
      const k = src.url.split("#")[0];
      if (!out.has(k)) out.set(k, src);
    }
    return [...out.values()];
  }

  function longerUsefulText(a, b) {
    const aa = String(a || "").trim(), bb = String(b || "").trim();
    if (!aa) return bb;
    if (!bb) return aa;
    return bb.length > aa.length ? bb : aa;
  }

  function uniqueCleanTopics(values = []) {
