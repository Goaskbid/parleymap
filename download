    window.addEventListener("scroll", () => els.backTop?.classList.toggle("is-visible", window.scrollY > 500));
    document.addEventListener("pointerover", delegatedHover);
    document.addEventListener("pointermove", moveHover);
    document.addEventListener("pointerout", (e) => { if (e.target.closest("[data-hover-title]")) hideHover(); });
