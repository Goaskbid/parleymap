  function renderSummitPills() {
    if (!els.summitPills) return;
    const summitItems = summitGroups().map((g) => ({ ...g, itemType: "summit", dedupeKey: eventDedupeKey(g.title, g.date, g.location?.city) }));
    const agendaItems = eventAgendas.filter((agenda) => new Date(agenda.endsAt || agenda.startsAt) >= new Date(now.getTime() - 150 * DAY)).map((agenda) => ({ itemType: "agenda", key: agenda.id, title: agenda.title, date: agenda.startsAt, location: agenda.location, people: agendaPeople(agenda), sources: agenda.sourcePack || [], why: agenda.whyItMatters || "Public event agenda card.", dedupeKey: eventDedupeKey(agenda.title, agenda.startsAt, agenda.location?.city) }));
    const merged = new Map();
    for (const item of [...agendaItems, ...summitItems]) {
      const k = item.dedupeKey;
      const prev = merged.get(k);
      if (!prev) { merged.set(k, item); continue; }
      const people = [...(prev.people || []), ...(item.people || [])].filter(Boolean);
      const byId = new Map(people.map((p) => [p.id || p.canonicalName, p]));
      merged.set(k, { ...prev, people: [...byId.values()], sources: [...(prev.sources || []), ...(item.sources || [])], why: prev.why || item.why });
    }
    const groups = [...merged.values()].sort((a, b) => Math.abs(daysFromNow(a.date)) - Math.abs(daysFromNow(b.date))).slice(0, 12);
    els.summitPills.innerHTML = groups.length ? groups.map((g) => {
      const names = g.people.slice(0, 5).map((p) => shortName(p.canonicalName)).join(", ");
      const faces = g.people.slice(0, 6).map((p) => miniFace(p)).join("");
      const label = oneLine(cleanEventTitle(g.title), 34);
      const body = g.itemType === "agenda" ? g.why : (names ? "Public cards include: " + names + ". " : "") + "Click to focus this public event window.";
      return `<button type="button" class="summit-pill" data-summit-key="${esc(g.key)}" data-summit-type="${esc(g.itemType)}" data-hover-title="${esc(cleanEventTitle(g.title))}" data-hover-detail="${esc(compactDate(g.date) + " · " + g.location.city)}" data-hover-body="${esc(body)}"><span class="summit-icon">${esc(stopIcon({ kind: "future", title: g.title }))}</span><strong>${esc(label)}</strong><em>${esc(compactDate(g.date))} · ${flagHtml(g.location.countryCode, g.location.countryName)} ${esc(g.location.city)}</em><span class="summit-faces">${faces}</span></button>`;
    }).join("") : `<span class="summit-empty">No announced public summit windows in the current pilot.</span>`;
    qsAll("[data-summit-key]", els.summitPills).forEach((b) => b.addEventListener("click", () => b.dataset.summitType === "agenda" ? focusAgenda(b.dataset.summitKey) : focusSummit(b.dataset.summitKey)));
    schedulePortraitHydration();
  }

  function eventDedupeKey(title, date, city) {
    const d = date ? new Date(date).toISOString().slice(0, 10) : "";
    return `${d}|${key(city)}|${key(cleanEventTitle(title)).replace(/summitwindow|announced|public|meeting|conference/g, "")}`;
  }

  function cleanEventTitle(title) {
    return String(title || "Event").replace(/ announced summit window| announced summit| public summit window/ig, "").replace(/\s+/g, " ").trim();
  }

  function summitGroups() {
    const futureRecords = appearances.filter((a) => isFuture(a) && /summit|g7|g20|nato|conference|forum/i.test([a.title, a.eventType, ...(a.topics || [])].join(" ")));
    const m = new Map();
    for (const a of futureRecords) {
      const k = `${new Date(a.startsAt).toISOString().slice(0, 10)}|${a.location.city}|${a.title}`;
      const g = m.get(k) || { key: k, title: a.title, date: a.startsAt, location: a.location, records: [], people: [], sources: [] };
      g.records.push(a);
      const p = peopleById.get(a.personId);
      if (p && !g.people.some((x) => x.id === p.id)) g.people.push(p);
      (a.sourcePack || []).forEach((src) => g.sources.push(src));
      m.set(k, g);
    }
    return [...m.values()].sort((a, b) => new Date(a.date) - new Date(b.date));
  }

  function focusSummit(keyValue) {
    const g = summitGroups().find((x) => x.key === keyValue);
    if (!g) return;
    stopPlayback();
    selectedPerson = null;
    selectedRoster = null;
    timeline = [];
    currentStep = -1;
    if (els.roster) els.roster.value = "";
    if (els.stepBrief) els.stepBrief.hidden = true;
    clearMap();
    els.mapTitle.textContent = g.title;
    els.mapStatus.textContent = `${compactDate(g.date)} · ${g.location.city}. Public summit window, not a travel guarantee.`;
    const attendees = deOverlapAnchors(g.people.map((p) => ({ roster: rosterForPerson(p), person: p, anchor: g.location })));
    if (!fallbackMode && map) {
      drawHeat(g.location, 1.8, "#ffc247");
      drawDisplayLeaderLines(attendees);
      attendees.forEach((item) => {
        const display = item.anchor;
        const marker = L.marker([display.lat, display.lng], { icon: personDivIcon(item.roster || item.person, item.person, { label: shortName(item.person.canonicalName) }), riseOnHover: true, keyboard: true });
        marker.on("click", () => selectRoster((item.roster || rosterForPerson(item.person))?.id));
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.person.canonicalName, detail: `${compactDate(g.date)} · ${g.location.city}`, body: `${g.title}. Public card places this figure in the announced summit window.` }));
        marker.on("mousemove", (e) => moveHover(e.originalEvent));
        marker.on("mouseout", hideHover);
        marker.addTo(layers.markers);
      });
