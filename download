  function dedupeTopicMigrationItems(items = []) {
    const out = [];
    const seen = new Set();
    for (const x of items) {
      const loc = x.location || {};
      const k = [new Date(x.startsAt || x.date || now).toISOString().slice(0,10), key(loc.city), key(cleanEventTitle(x.title || x.name || x.type))].join("|");
      if (seen.has(k)) continue;
      seen.add(k);
      out.push(x);
    }
    return out;
  }

  function sampleSequence(items, n) {
    if (items.length <= n) return items;
    const out = [];
    const step = (items.length - 1) / (n - 1);
    for (let i = 0; i < n; i++) out.push(items[Math.round(i * step)]);
    return out.filter(Boolean);
  }

