        marker.on("click", () => selectRoster((item.roster || rosterForPerson(item.person))?.id));
        marker.on("mouseover", (e) => showHoverAt(e.originalEvent, { title: item.person.canonicalName, detail: `${flagEmoji(loc.countryCode)} ${loc.city}`, body: `${matches.length} public records are clustered here in the current pilot.` }));
