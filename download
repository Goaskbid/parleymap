  function isFuture(a) { return a.status === "ANNOUNCED_FUTURE" || new Date(a.startsAt) > now; }
  function daysFromNow(d) { return Math.round((new Date(d) - now) / DAY); }
  function dateScore(d) { return d ? new Date(d).getTime() : 0; }
