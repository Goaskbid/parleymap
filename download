    qsAll('[data-web-roster]', els.influenceWeb).forEach((el) => el.addEventListener('click', () => activateWebPerson(el.dataset.webRoster)));
    qsAll('[data-web-event]', els.influenceWeb).forEach((el) => el.addEventListener('click', () => activateWebEvent(el.dataset.webEvent)));
    bindPersonButtons(els.influenceWeb);
    schedulePortraitHydration();
  }

  function activateWebEvent(eventName) {
    if (!eventName || !els.influenceWeb) return;
    qsAll('.web510-link', els.influenceWeb).forEach((line) => { const on = line.dataset.webFamilyName === eventName; line.classList.toggle('is-active', on); line.classList.toggle('is-dim', !on); });
    qsAll('.web510-person', els.influenceWeb).forEach((node) => { const id = node.dataset.webRoster; const has = qsAll('.web510-link', els.influenceWeb).some((line) => line.dataset.webFamilyName === eventName && line.dataset.webPersonId === id); node.classList.toggle('is-selected', has); node.classList.toggle('is-muted', !has); });
    qsAll('.web510-event', els.influenceWeb).forEach((node) => node.classList.toggle('is-selected', node.dataset.webEvent === eventName));
    const pane = qs('#web-contacts', els.influenceWeb); const family = eventFamilies().find((f) => f.name === eventName); const hit = family ? familyHits(family) : { people: [], agendas: [] };
    const agendaLinks = (hit.agendas || []).slice(0, 6).map((a) => `<button type="button" class="source-link" data-agenda-id="${esc(a.id || key(a.title))}">${esc(cleanEventTitle(a.title))}</button>`).join('');
    if (pane) pane.innerHTML = `<h4>${esc(eventName)}</h4><p>${hit.people.length} named people and ${hit.agendas.length} agenda/watch cards are connected to this event system in the current build.</p><div class="web510-grid">${hit.people.slice(0, 28).map((p) => webPersonChipV510(p, p.roleTitle)).join('') || '<span>Named participants appear as records are promoted.</span>'}</div><div class="web510-sources">${agendaLinks}</div>`;
    qsAll('[data-agenda-id]', pane || els.influenceWeb).forEach((b) => b.addEventListener('click', () => focusAgenda(b.dataset.agendaId)));
    bindPersonButtons(pane || els.influenceWeb); schedulePortraitHydration();
  }

  function activateWebPerson(rosterId) {
    const r = rosterById.get(rosterId);
    if (!r || !els.influenceWeb) return;
    const p = mappedPersonForRoster(r);
    qsAll('.web510-link', els.influenceWeb).forEach((line) => { const on = line.dataset.webPersonId === rosterId; line.classList.toggle('is-active', on); line.classList.toggle('is-dim', !on); });
    qsAll('.web510-person', els.influenceWeb).forEach((node) => { const on = node.dataset.webPersonId === rosterId; node.classList.toggle('is-selected', on); node.classList.toggle('is-muted', !on); });
    const recs = p ? (appearancesByPerson.get(p.id) || []) : [];
    const fams = coreEventFamiliesV49().filter((f) => recs.some((a) => f.rx.test(recordHay(a))));
    const counterpartIds = new Set(recs.flatMap((a) => counterpartyIdsByAppearance.get(a.id) || []));
    const counterparts = [...counterpartIds].map((id) => peopleById.get(id)).filter(Boolean);
    const pane = qs('#web-contacts', els.influenceWeb);
    if (pane) pane.innerHTML = `<h4>${esc(r.name)}</h4><p>${recs.length} public records across ${fams.length} event systems in the current build.</p><div class="topic-pills">${fams.map((f) => `<button type="button" class="topic-pill" data-network-name="${esc(f.name)}">${esc(f.name)}</button>`).join('') || '<span class="topic-pill">watch profile</span>'}</div><div class="web510-grid">${counterparts.slice(0, 18).map((x) => webPersonChipV510(x, x.roleTitle)).join('') || '<span>Counterpart faces appear as named records are promoted.</span>'}</div>`;
    qsAll('[data-network-name]', pane || els.influenceWeb).forEach((b) => b.addEventListener('click', () => focusNetwork(b.dataset.networkName)));
    if (p) renderProfile(p, recs.at(-1)); else selectRoster(rosterId);
    bindPersonButtons(pane || els.influenceWeb); schedulePortraitHydration();
  }


})();
