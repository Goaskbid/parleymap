  function renderEventOverlapMatrix() {
    if (!els.eventOverlapMatrix) return;
    const families = eventFamilies()
      .filter((f)=>!/^Federal Reserve FOMC/i.test(f.name))
      .slice(0, 18);
    const rows = families.map((f)=>{
      const hit = familyHits(f);
      return { family:f, hit, ids:new Set(hit.people.map((p)=>p.id)) };
    });
    const matrix = rows.map((r,i)=> rows.map((c,j)=>{
      const sharedIds = [...r.ids].filter((id)=>c.ids.has(id));
      const denom = Math.max(1, Math.min(r.ids.size || 1, c.ids.size || 1));
      return { pct: i===j ? 100 : Math.round(sharedIds.length / denom * 100), shared: i===j ? r.ids.size : sharedIds.length, sharedIds };
    }));
    const hotPairs = [];
    for (let i=0;i<rows.length;i++) for (let j=i+1;j<rows.length;j++) {
      const cell = matrix[i][j];
      if (cell.pct > 0) hotPairs.push({a:rows[i], b:rows[j], cell});
    }
    hotPairs.sort((x,y)=>y.cell.pct-x.cell.pct || y.cell.shared-x.cell.shared);
    const clusterHtml = hotPairs.slice(0,8).map((x)=>`<button type="button" class="v490-cluster ${x.cell.pct >= 70 ? 'hot' : x.cell.pct >= 35 ? 'warm' : ''}" data-matrix-event="${esc(x.a.family.name)}" data-hover-title="${esc(x.a.family.name + ' ↔ ' + x.b.family.name)}" data-hover-detail="${esc(x.cell.pct + '% shared-attendee overlap')}" data-hover-body="${esc(x.cell.shared + ' named people are visible in both event systems in this build.')}" ><span>${esc(x.a.family.name)}</span><i>↔</i><span>${esc(x.b.family.name)}</span><b>${x.cell.pct}</b></button>`).join('');
    const header = `<tr><th class="v490-corner">Event system</th>${rows.map((r)=>`<th title="${esc(r.family.name)}"><span>${esc(shortEventLabel(r.family.name))}</span></th>`).join('')}</tr>`;
    const body = rows.map((r,i)=>`<tr><th class="v490-y" title="${esc(r.family.name)}"><button type="button" data-matrix-event="${esc(r.family.name)}">${esc(r.family.name)}</button></th>${rows.map((c,j)=>{ const cell = matrix[i][j]; const title = `${r.family.name} / ${c.family.name}`; const detail = `${cell.pct}% overlap · ${cell.shared} named ${cell.shared===1?'person':'people'}`; return `<td><button type="button" class="v490-matrix-cell ${i===j?'self':''}" style="--heat:${cell.pct}" data-matrix-event="${esc(r.family.name)}" data-hover-title="${esc(title)}" data-hover-detail="${esc(detail)}" data-hover-body="${esc(cell.shared ? 'Click to open the event layer on the map and in the profile rail.' : 'No named overlap in the current source-backed build.')}" aria-label="${esc(detail)}"><strong>${i===j ? '100' : cell.pct}</strong><span>${cell.shared}</span></button></td>`; }).join('')}</tr>`).join('');
    els.eventOverlapMatrix.innerHTML = `<div class="v490-panel-head"><strong>Shared-attendee overlap</strong><span>Rows and columns are both visible. Gold cells show event systems that pull in the same people; click any row or cell to open that layer.</span></div><div class="v490-clusters">${clusterHtml}</div><div class="v490-matrix-shell"><table class="v490-matrix"><thead>${header}</thead><tbody>${body}</tbody></table></div>`;
    qsAll('[data-matrix-event]', els.eventOverlapMatrix).forEach((b)=>b.addEventListener('click',()=>focusNetwork(b.dataset.matrixEvent)));
  }

