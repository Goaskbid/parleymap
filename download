  async function loadLeafletWithFallback() {
    try {
      await Promise.race([loadLeaflet(), wait(2600).then(() => { throw new Error("leaflet-timeout"); })]);
      if (!window.L) throw new Error("leaflet-missing");
      initLeafletMap();
    } catch (_) {
      initFallbackMap();
    }
    renderOpeningMap();
  }

  function loadLeaflet() {
    if (window.L) return Promise.resolve();
    const css = document.createElement("link");
    css.rel = "stylesheet";
    css.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
    document.head.appendChild(css);
    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.async = true;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  function initLeafletMap() {
    fallbackMode = false;
    els.fallback.hidden = true;
    els.map.hidden = false;
    map = L.map(els.map, { zoomControl: true, worldCopyJump: true, minZoom: 2, maxZoom: 12, preferCanvas: true }).setView([25, 10], 2);
    L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
      maxZoom: 12,
      attribution: "OpenStreetMap contributors, CARTO",
      subdomains: "abcd"
    }).addTo(map);
    layers = {
      heat: L.layerGroup().addTo(map),
      calls: L.layerGroup().addTo(map),
      route: L.layerGroup().addTo(map),
      markers: L.layerGroup().addTo(map),
      moving: L.layerGroup().addTo(map),
      vehicles: L.layerGroup().addTo(map),
      labels: L.layerGroup().addTo(map)
    };
    map.on("click", hideHover);
  }

