  function intersectionSizeV49(a, b) {
    let n = 0;
    for (const v of a) if (b.has(v)) n++;
    return n;
  }

  function renderEventOverlapMatrix() {
    if (!els.eventOverlapMatrix) return;
    const fams = coreEventFamiliesV49();
    const hits = fams.map((fam) => familyHits(fam));
    const personSets = hits.map((h) => new Set((h.people || []).map((p) => p.id)));
    const labelFor = (name) => name.replace("Jackson Hole", "JH").replace("ECB Sintra", "Sintra").replace("IMF / World Bank", "IMF/WB").replace("Shangri-La", "Shangri");
    const cells = [];
    for (let r = 0; r < fams.length; r++) {
      const row = [];
      for (let c = 0; c < fams.length; c++) {
        const shared = intersectionSizeV49(personSets[r], personSets[c]);
        const denom = Math.max(1, Math.min(personSets[r].size || 1, personSets[c].size || 1));
        const score = r === c ? (personSets[r].size ? 100 : 0) : Math.round((shared / denom) * 100);
        row.push({ score, shared });
      }
      cells.push(row);
    }
    const clusters = [];
    for (let r = 0; r < fams.length; r++) {
      for (let c = r + 1; c < fams.length; c++) {
        if (cells[r][c].score > 0) clusters.push({ a: fams[r], b: fams[c], score: cells[r][c].score, shared: cells[r][c].shared });
      }
    }
    clusters.sort((a, b) => b.score - a.score || b.shared - a.shared);
    const clusterHtml = clusters.slice(0, 8).map((x) => `<button type="button" class="matrix-cluster-v49" data-network-name="${esc(x.a.name)}" data-hover-title="${esc(x.a.name + ' ↔ ' + x.b.name)}" data-hover-detail="${esc(x.score + '/100 overlap · ' + x.shared + ' shared people')}" data-hover-body="${esc('Bright cells mean the same public figures are showing up in both event systems. Use this to spot communities, not attendance claims.')}" ><span>${esc(x.a.name)}</span><b>↔</b><span>${esc(x.b.name)}</span><em>${x.score}</em></button>`).join("");
    const head = fams.map((fam) => `<button type="button" class="matrix-head-v49" data-network-name="${esc(fam.name)}" data-hover-title="${esc(fam.name)}" data-hover-detail="${esc((hits[fams.indexOf(fam)].people || []).length + ' named people')}" data-hover-body="${esc('Open this event layer on the map.')}" title="${esc(fam.name)}">${esc(labelFor(fam.name))}</button>`).join("");
    const body = fams.map((fam, r) => {
      const rowCells = cells[r].map((cell, c) => {
        const intensity = Math.max(0, Math.min(100, cell.score));
        const detail = `${cell.score}/100 · ${cell.shared} shared people`;
        return `<button type="button" class="matrix-cell-v49" style="--heat:${intensity}" data-network-name="${esc(fam.name)}" data-hover-title="${esc(fam.name + ' ↔ ' + fams[c].name)}" data-hover-detail="${esc(detail)}" data-hover-body="${esc('The large number is overlap strength; the smaller number is the count of named people shared by both event systems.')}" aria-label="${esc(fam.name + ' and ' + fams[c].name + ': ' + detail)}"><b>${cell.score}</b><small>${cell.shared}</small></button>`;
      }).join("");
      return `<button type="button" class="matrix-y-v49" data-network-name="${esc(fam.name)}" title="${esc(fam.name)}">${esc(labelFor(fam.name))}</button>${rowCells}`;
    }).join("");
    els.eventOverlapMatrix.innerHTML = `<div class="matrix-panel-v49"><header><strong>Shared-attendee overlap</strong><span>Read it like a correlation map. The y-axis is back; bright cells show event systems drawing the same named people.</span></header><div class="matrix-clusters-v49">${clusterHtml}</div><div class="matrix-grid-v49" style="--n:${fams.length}"><div class="matrix-corner-v49">Event system</div>${head}${body}</div></div>`;
    qsAll("[data-network-name]", els.eventOverlapMatrix).forEach((b) => b.addEventListener("click", () => focusNetwork(b.dataset.networkName)));
  }

