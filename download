      { name: "Saudi PIF", rx: /public investment fund|pif|yasir al-rumayyan|fii/i, type: "sovereign wealth" },
      { name: "Mubadala", rx: /mubadala|abu dhabi investment/i, type: "sovereign wealth" },
      { name: "Shell", rx: /shell|wael sawan/i, type: "energy" },
      { name: "BP", rx: /\bbp\b|murray auchincloss/i, type: "energy" },
      { name: "Chatham House", rx: /chatham house/i, type: "think tank" },
      { name: "Aspen Institute", rx: /aspen institute|aspen security|aspen ideas/i, type: "think tank" }
    ];
    const byName = new Map();
    const add = (item) => {
      const name = oneLine(item.name || item.organization || item.title || "", 42).trim();
      if (!name) return;
      const terms = [name, item.mark, item.category, item.type, item.homeCity, item.why, ...(item.representatives || []), ...(item.topics || []), ...(item.eventPresence || [])].filter(Boolean).map(escapeRegex).slice(0, 24);
      const rx = item.rx instanceof RegExp ? item.rx : new RegExp(terms.length ? terms.join("|") : escapeRegex(name), "i");
      const next = { ...item, name, rx, type: item.type || item.category || "organisation", eventPresence: item.eventPresence || [] };
      const existing = byName.get(key(name));
      if (existing) byName.set(key(name), { ...existing, ...next, eventPresence: [...new Set([...(existing.eventPresence || []), ...(next.eventPresence || [])])] });
      else byName.set(key(name), next);
    };
    base.forEach(add);
    organizationProfiles.forEach(add);
    return [...byName.values()];
